@page
@model _2FA.Areas.Identity.Pages.Account.PasswordExpiryModel
@{
    ViewData["Title"] = "Contraseña vencida";
}

<h2>Su contraseña ha vencido</h2>

@if (Model.RequirePasswordChangeOnExpiry)
{
    <p>El administrador requiere el cambio de contraseña. Será redirigido para cambiarla.</p>
    <form method="post" asp-page-handler="Change">
        <button type="submit" class="btn btn-primary">Cambiar contraseña</button>
    </form>
}
else
{
    <p>¿Desea mantener su contraseña actual o cambiarla ahora?</p>

    <form method="post" asp-page-handler="Keep">
        <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
        <button type="submit" class="btn btn-secondary">Mantener contraseña</button>
    </form>

    <form method="post" asp-page-handler="Change" style="display:inline;margin-left:8px;">
        <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
        <button type="submit" class="btn btn-primary">Cambiar ahora</button>
    </form>
}
