@page
@model CompanySelectionModel
@{
    ViewData["Title"] = "Seleccionar Compañía";
}

<h1>@ViewData["Title"]</h1>

<div class="m-0 row justify-content-center">
    <div class="col-md-3">
        <section>
            <img src="~/img/Company.png" alt="Company Selection Image" class="img-fluid" />
        </section>
    </div>
    <div class="col-md-4">
    <br />
    <br />
    <br />
        <form method="post">
            <h4>Seleccione la compañía a la que desea ingresar:</h4>
            <hr />
            @foreach (var company in Model.UserCompanies)
            {
                <div class="form-check">
                    <input class="form-check-input" type="radio" name="selectedCompanyId" id="company@company.Id" value="@company.Id" required>
                    <label class="form-check-label" for="company@company.Id">
                        @company.Name
                    </label>
                </div>
            }
            <br />
            <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
            <button type="submit" class="w-100 btn btn-lg btn-primary">Ingresar</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}