@page
@model LoginModel

@{
    ViewData["Title"] = "Ingreso";
}

<div class="m-0 row justify-content-center">
    <h1>@ViewData["Title"]</h1>
    <div class="col-md-3">
        <section>
            <img src="~/img/Login.png" alt="Login Image" class="img-fluid" />
        </section>
    </div>
    <div class="col-md-4">
        <section>
            <form id="account" method="post">
                <h2>Utilice su cuenta local</h2>
                <hr />
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <div class="form-floating">
                    <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" />
                    <label asp-for="Input.Email" class="form-label"></label>
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>
                <br />
                <div class="form-floating">
                    <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" />
                    <label asp-for="Input.Password" class="form-label"></label>
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>
                <div>
                    <div class="checkbox">
                        <label asp-for="Input.RememberMe" class="form-label">
                            <input class="form-check-input" asp-for="Input.RememberMe" />
                            @Html.DisplayNameFor(m => m.Input.RememberMe)
                        </label>
                    </div>
                </div>
                <br />
                <div>
                    <button id="login-submit" type="submit" class="w-100 btn btn-lg btn-primary">Ingresar</button>
                </div>
                <br />
                <div class="row">
                    <div class="col-6">
                        <a id="forgot-password" asp-page="./ForgotPassword">Olvidó su contraseña?</a>
                    </div>
                    <div class="col-6">
                        <a id="resend-confirmation" asp-page="./ResendEmailConfirmation">Reenviar confirmación</a>
                    </div>
                </div>
            </form>
        </section>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
