<script>
    document.addEventListener('DOMContentLoaded', function () {
        var contactModal = document.getElementById('contactModal');
        contactModal.addEventListener('show.bs.modal', function (event) {
            // Botón que activó el modal
            var button = event.relatedTarget;
            // Extrae la información del atributo data-subject
            var subject = button.getAttribute('data-subject');
            // Obtiene el campo de asunto del formulario dentro del modal
            var subjectInput = contactModal.querySelector('#subjectInput');
            // Actualiza el valor del campo con el asunto predefinido
            subjectInput.value = subject;
        });

        // Manejador del formulario para abrir el cliente de correo
        var contactForm = document.getElementById('contactForm');
        contactForm.addEventListener('submit', function(event) {
            event.preventDefault(); // Evita que el formulario se envíe de forma tradicional

            var subject = document.getElementById('subjectInput').value;
            var message = document.getElementById('messageTextarea').value;
            var companyEmail = 'tu-email@empresa.com'; // Cambia esto por la dirección de correo de tu empresa

            // Construye el enlace mailto
            var mailtoLink = `mailto:${companyEmail}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(message)}`;

            // Abre el cliente de correo del usuario
            window.location.href = mailtoLink;

            // Cierra el modal después de abrir el cliente de correo (opcional)
            var modal = bootstrap.Modal.getInstance(contactModal);
            modal.hide();
        });
    });

    document.addEventListener("DOMContentLoaded", function () {
        const conceptModal = document.getElementById('conceptModal');
        if (conceptModal && conceptModal.parentElement !== document.body) {
            document.body.appendChild(conceptModal);
        }

        conceptModal.addEventListener('show.bs.modal', function (event) {
            const select = conceptModal.querySelector('#PaymentConceptId');
            
            // Limpiar y poner el placeholder
            select.innerHTML = '<option value="">-- Seleccione --</option>';

            fetch('/PayrollTmpHeaders/GetPaymentConcepts')
                .then(r => r.json())
                .then(data => {
                    data.forEach(pc => {
                        let opt = document.createElement("option");
                        opt.value = pc.id;
                        opt.text = pc.name;
                        select.appendChild(opt);
                    });
                })
                .catch(err => console.error("Error cargando conceptos:", err));
        });
    });

</script>

<!-- Company Switching JavaScript -->
<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Handle company switching
        document.addEventListener('click', function(e) {
            if (e.target.classList.contains('company-switch-btn')) {
                e.preventDefault();
                const companyId = e.target.getAttribute('data-company-id');
                switchCompany(companyId);
            }
        });

        function switchCompany(companyId) {
            // Show loading indicator
            showLoading();

            fetch('/Home/SwitchCompanyAjax', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                },
                body: JSON.stringify({ selectedCompanyId: parseInt(companyId) })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    // Update company display in navbar
                    updateCompanyDisplay(data.companyName);

                    // Clear current page data and reload
                    clearAndReloadPageData();

                    // Show success message
                    showSuccessMessage('Compañía cambiada exitosamente');
                } else {
                    showErrorMessage(data.message || 'Error al cambiar compañía');
                }
            })
            .catch(error => {
                console.error('Error:', error);
                showErrorMessage('Error al cambiar compañía');
            })
            .finally(() => {
                hideLoading();
            });
        }

        function showLoading() {
            // Add loading overlay
            const loadingDiv = document.createElement('div');
            loadingDiv.id = 'companySwitchLoading';
            loadingDiv.innerHTML = `
                <div style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 9999; display: flex; justify-content: center; align-items: center;">
                    <div style="background: white; padding: 20px; border-radius: 5px; text-align: center;">
                        <i class="fas fa-spinner fa-spin"></i>
                        <p>Cambiando compañía...</p>
                    </div>
                </div>
            `;
            document.body.appendChild(loadingDiv);
        }

        function hideLoading() {
            const loadingDiv = document.getElementById('companySwitchLoading');
            if (loadingDiv) {
                loadingDiv.remove();
            }
        }

        function updateCompanyDisplay(companyName) {
            // Update the company display component
            const companyDisplay = document.querySelector('.navbar-nav .nav-item span.nav-link');
            if (companyDisplay) {
                companyDisplay.innerHTML = '<i class="fas fa-building"></i> ' + companyName;
            }
        }

        function clearAndReloadPageData() {
            // Always redirect to Home/Index to close open views
            window.location.href = '/Home/Index';
        }

        function showSuccessMessage(message) {
            showMessage(message, 'success');
        }

        function showErrorMessage(message) {
            showMessage(message, 'danger');
        }

        function showMessage(message, type) {
            const alertDiv = document.createElement('div');
            alertDiv.className = `alert alert-${type} alert-dismissible fade show position-fixed`;
            alertDiv.style.cssText = 'top: 20px; right: 20px; z-index: 10000; min-width: 300px;';
            alertDiv.innerHTML = `
                ${message}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            `;
            document.body.appendChild(alertDiv);

            // Auto remove after 5 seconds
            setTimeout(() => {
                if (alertDiv.parentNode) {
                    alertDiv.remove();
                }
            }, 5000);
        }
    });
</script>

