<body class="corporate-background">
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-light corporate-nav">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <img src="@Url.Content("~/img/logo.png")" alt="Logo" style="max-width: 70px; max-height:auto" />
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarSupportedContent">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link active" aria-current="page" asp-area="" asp-controller="Home" asp-action="Index">Inicio</a>
                        </li>
                        @if (SignInManager.IsSignedIn(User))
                        {
                            <!-- Company selection is handled via the Home Card -->
                            <!-- Current Company Display -->
                        <li class="nav-item">
                            <a class="nav-link active" aria-current="page" asp-area="" >@await Component.InvokeAsync("CurrentCompanyDisplay")</a>
                        </li>
                        }
                        <li class="nav-item">
                            <a class="nav-link" href="#contactModal" data-bs-toggle="modal" data-subject="Consulta Empresarial">Contacto</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>
    @{
        var breadcrumbs = ViewData["Breadcrumb"] as List<BreadcrumbItem>;
    }
    @if (breadcrumbs != null)
    {
        <nav aria-label="breadcrumb" class="breadcrumb-nav">
            <ol class="breadcrumb">
                @foreach (var item in breadcrumbs)
                {
                    if (!string.IsNullOrEmpty(item.Url))
                    {
                        var breadcrumbUrl = item.Url.StartsWith("/") ? item.Url : $"/{item.Url.TrimStart('/')}";
                        <li class="breadcrumb-item"><a href="@breadcrumbUrl">@item.Text</a></li>
                    }
                    else
                    {
                        <li class="breadcrumb-item active" aria-current="page">@item.Text</li>
                    }
                }
            </ol>
        </nav>
    }
    <div class="content-container">
        <div role="main" class="content-area">
            <div class="main-panel">
                @RenderBody()
            </div>
        </div>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2025 - 2FA - <a style="text-decoration-style: none;" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>


    <div class="modal fade" id="contactModal" tabindex="-1" aria-labelledby="contactModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="contactModalLabel">Formulario de Contacto</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="contactForm">
                <div class="mb-3">
                    <label for="subjectInput" class="form-label">Asunto</label>
                    <input type="text" class="form-control" id="subjectInput" name="subject" readonly>
                </div>
                <div class="mb-3">
                    <label for="messageTextarea" class="form-label">Mensaje</label>
                    <textarea class="form-control" id="messageTextarea" name="message" rows="5"></textarea>
                </div>
                <button type="submit" class="btn btn-primary">Enviar Correo</button>
                </form>
            </div>
            </div>
        </div>
    </div>


<div class="modal fade" id="conceptModal" tabindex="-1" aria-labelledby="conceptModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="conceptModalLabel">Agregar Concepto de Pago</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <form id="conceptForm">
                    <input type="hidden" name="PayrollTmpEmployeeId" id="PayrollTmpEmployeeId" />
                    <input type="hidden" name="PayrollTmpHeaderId" id="payrollTmpHeaderId" value="@ViewBag.PayrollTmpHeaderId" />

                    <div class="mb-3">
                        <label for="PaymentConceptId" class="form-label">Concepto</label>
                        <select class="form-select" name="PaymentConceptId" id="PaymentConceptId" required>
                            <option value="">-- Seleccione --</option>
                            @if (ViewBag.PaymentConcepts != null)
                            {
                                foreach (var pc in ViewBag.PaymentConcepts)
                                {
                                    <option value="@pc.Id">@pc.Name</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label for="Hours" class="form-label">Horas</label>
                            <input type="number" step="0.01" class="form-control" name="Hours" id="Hours" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label for="UnitAmount" class="form-label">Monto Unitario</label>
                            <input type="number" step="0.01" class="form-control" name="UnitAmount" id="UnitAmount" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label for="PayFactor" class="form-label">Factor</label>
                            <input type="number" step="0.01" class="form-control" name="PayFactor" id="PayFactor" value="1" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="TotalAmount" class="form-label">Monto Total</label>
                        <input type="number" step="0.01" class="form-control" name="TotalAmount" id="TotalAmount" readonly />
                    </div>

                    <div class="mb-3">
                        <label for="Notes" class="form-label">Notas</label>
                        <textarea class="form-control" name="Notes" id="Notes"></textarea>
                    </div>
                    @Html.AntiForgeryToken()
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary" id="saveConceptBtn">Guardar</button>
            </div>
        </div>
    </div>
</div>


