@model _2FA.Data.Entities.CostCenterEntity

@{
    ViewData["Title"] = "Details";
}

<div style="text-align: center;">
    <h2>Detalle del Banco</h2>
</div>

<div class="m-0 row justify-content-center">
    <div class="col-md-8">
        <div class="card">
            <card-header>
                <div class="p-3">
                    <a title="Editar registro" class="btn-action" asp-action="Edit" asp-route-id="@Model?.Id"><i class="fa-solid fa-pen-to-square"></i></a>
                    &nbsp;
                    <a title="Regresar" class="btn-action" asp-action="Index"><i class="fa-solid fa-left-long"></i></a>
                </div>
            </card-header>
            <div class="card-body">
                <hr />
                <div class="row">
                    <div class="col-md-6">
                        <dl class="row">
                            <dt class = "col-sm-4">
                                @Html.DisplayNameFor(model => model.Name)
                            </dt>
                            <dd class = "col-sm-8">
                                @Html.DisplayFor(model => model.Name)
                            </dd>
                            <dt class = "col-sm-4">
                                @Html.DisplayNameFor(model => model.IsActive)
                            </dt>
                            <dd class = "col-sm-8">
                                @if(Model.IsActive)
                                {
                                    <span class="badge bg-success">Sí</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">No</span>
                                }
                            </dd>
                        </dl>
                    </div>
                    <div class="col-md-6">
                        <dl class="row">
                            <dt class = "col-sm-4">
                                @Html.DisplayNameFor(model => model.Created)
                            </dt>
                            <dd class = "col-sm-8">
                                @Html.DisplayFor(model => model.Created)
                            </dd>
                            <dt class = "col-sm-4">
                                @Html.DisplayNameFor(model => model.CreatedBy)
                            </dt>
                            <dd class = "col-sm-8">
                                @Html.DisplayFor(model => model.CreatedBy)
                            </dd>
                            <dt class = "col-sm-4">
                                @Html.DisplayNameFor(model => model.Modified)
                            </dt>
                            <dd class = "col-sm-8">
                                @Html.DisplayFor(model => model.Modified)
                            </dd>
                            <dt class = "col-sm-4">
                                @Html.DisplayNameFor(model => model.ModifiedBy)
                            </dt>
                            <dd class = "col-sm-8">
                                @Html.DisplayFor(model => model.ModifiedBy)
                            </dd>
                            <dt class = "col-sm-4">
                                @Html.DisplayNameFor(model => model.Deleted)
                            </dt>
                            <dd class = "col-sm-8">
                                @Html.DisplayFor(model => model.Deleted)
                            </dd>
                            <dt class = "col-sm-4">
                                @Html.DisplayNameFor(model => model.DeletedBy)
                            </dt>
                            <dd class = "col-sm-8">
                                @Html.DisplayFor(model => model.DeletedBy)
                            </dd>
                            <dt class = "col-sm-4">
                                @Html.DisplayNameFor(model => model.IsDeleted)
                            </dt>
                            <dd class = "col-sm-8">
                                @if(Model.IsDeleted)
                                {
                                    <span class="badge bg-danger">Sí</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">No</span>
                                }
                            </dd>
                        </dl>
                    </div>
                </div>
            </div>
            
            @if (Model.CostCenterPaymentConceptAccounts != null && Model.CostCenterPaymentConceptAccounts.Any())
            {
                <div class="m-0 row justify-content-center mt-4">
                    <div class="col-md-10">
                        <div class="card">
                            <div class="card-header">
                                <h5>Cuentas Contables Asignadas</h5>
                            </div>
                            <div class="card-body">
                                <div class="row">
                                    @foreach (var item in Model.CostCenterPaymentConceptAccounts.Where(x => x.IsActive))
                                    {
                                        <div class="col-md-6 mb-3">
                                            <div class="card border-primary">
                                                <div class="card-body">
                                                    <h6 class="card-title">@item.PaymentConcept?.Name</h6>
                                                    <p class="card-text">
                                                        <strong>Cuenta:</strong> @item.Account?.AccountNumber<br />
                                                        <strong>Descripción:</strong> @item.Account?.Description
                                                    </p>
                                                    @if (!string.IsNullOrEmpty(item.Description))
                                                    {
                                                        <p class="card-text">
                                                            <strong>Notas:</strong> @item.Description
                                                        </p>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
