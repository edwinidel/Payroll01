@model _2FA.Data.Entities.DocumentTypeEntity

@{
    ViewData["Title"] = "Editar Tipo de Documento";
}

<h2>Editar Tipo de Documento</h2>

<form asp-action="Edit" enctype="multipart/form-data" method="post">
    <input type="hidden" asp-for="Id" />
    <div class="form-group">
        <label asp-for="Name" class="control-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Description" class="control-label"></label>
        <textarea asp-for="Description" class="form-control"></textarea>
    </div>
    <div class="form-group">
        <label>Firma</label>
        <div class="mb-3">
            <div class="form-check">
                <input class="form-check-input" type="radio" name="signatureType" id="uploadSignature" value="upload" checked>
                <label class="form-check-label" for="uploadSignature">
                    Subir archivo de firma
                </label>
            </div>
            <div class="form-check">
                <input class="form-check-input" type="radio" name="signatureType" id="drawSignature" value="draw">
                <label class="form-check-label" for="drawSignature">
                    Dibujar firma digital
                </label>
            </div>
        </div>

        <div id="uploadSection">
            <input type="file" name="signatureFile" class="form-control-file" accept="image/*,.pdf" />
            @if (Model.SignaturePath != null)
            {
                <div class="mt-2">
                    <small>Firma actual: <a href="@Model.SignaturePath" target="_blank">Ver</a></small>
                </div>
            }
        </div>

        <div id="drawSection" style="display: none;">
            <div class="border rounded p-3 mb-3">
                <canvas id="signaturePad" width="400" height="200" class="border" style="cursor: crosshair;"></canvas>
                <div class="mt-2">
                    <button type="button" id="clearSignature" class="btn btn-sm btn-secondary">Limpiar</button>
                </div>
            </div>
            <input type="hidden" name="signatureData" id="signatureData" />
        </div>
    </div>
    <div class="form-group">
        <label asp-for="SignerName" class="control-label"></label>
        <input asp-for="SignerName" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="SignerTitle" class="control-label"></label>
        <input asp-for="SignerTitle" class="form-control" />
    </div>
    <div class="form-group form-check">
        <input asp-for="IsActive" class="form-check-input" />
        <label asp-for="IsActive" class="form-check-label"></label>
    </div>
    <button type="submit" class="btn btn-primary">Guardar</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

<script>
document.addEventListener('DOMContentLoaded', function() {
    const uploadRadio = document.getElementById('uploadSignature');
    const drawRadio = document.getElementById('drawSignature');
    const uploadSection = document.getElementById('uploadSection');
    const drawSection = document.getElementById('drawSection');
    const signatureFile = document.getElementById('signatureFile');
    const canvas = document.getElementById('signaturePad');
    const clearBtn = document.getElementById('clearSignature');
    const signatureDataInput = document.getElementById('signatureData');

    let signaturePad = new SignaturePad(canvas);

    // Toggle sections based on radio selection
    function toggleSignatureType() {
        if (uploadRadio.checked) {
            uploadSection.style.display = 'block';
            drawSection.style.display = 'none';
            signatureFile.required = false;
            signatureDataInput.required = false;
        } else {
            uploadSection.style.display = 'none';
            drawSection.style.display = 'block';
            signatureFile.required = false;
            signatureDataInput.required = false;
        }
    }

    uploadRadio.addEventListener('change', toggleSignatureType);
    drawRadio.addEventListener('change', toggleSignatureType);

    // Clear signature
    clearBtn.addEventListener('click', function() {
        signaturePad.clear();
        signatureDataInput.value = '';
    });

    // Update hidden input when signature changes
    canvas.addEventListener('mouseup', updateSignatureData);
    canvas.addEventListener('touchend', updateSignatureData);

    function updateSignatureData() {
        if (!signaturePad.isEmpty()) {
            const dataURL = signaturePad.toDataURL('image/png');
            signatureDataInput.value = dataURL;
        } else {
            signatureDataInput.value = '';
        }
    }
});
</script>
