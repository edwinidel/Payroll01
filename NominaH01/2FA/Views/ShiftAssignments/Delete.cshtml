@model _2FA.Data.Entities.ShiftAssignmentEntity

@{
    ViewData["Title"] = "Delete";
}

<div style="text-align: center;">
    <h2>Eliminar Asignación de Turno</h2>
</div>

<div class="m-0 row justify-content-center">
    <div class="col-md-8">
        <div class="card">
            <card-header>
                <div class="p-3">
                    <a title="Regresar" class="btn-action" asp-action="Index"><i class="fa-solid fa-left-long"></i></a>
                </div>
            </card-header>
            <div class="card-body">
                <h3>¿Está seguro de que desea eliminar este registro?</h3>
                <hr />
                <dl class="row">
                    <dt class = "col-sm-2">
                        Empleado
                    </dt>
                    <dd class = "col-sm-10">
                        @Html.DisplayFor(model => model.Employee.FullName)
                    </dd>
                    <dt class = "col-sm-2">
                        Turno
                    </dt>
                    <dd class = "col-sm-10">
                        @Html.DisplayFor(model => model.Shift.Name)
                    </dd>
                    <dt class = "col-sm-2">
                        @Html.DisplayNameFor(model => model.Date)
                    </dt>
                    <dd class = "col-sm-10">
                        @Html.DisplayFor(model => model.Date)
                    </dd>
                    <dt class = "col-sm-2">
                        Horario
                    </dt>
                    <dd class = "col-sm-10">
                        @Html.DisplayFor(model => model.Schedule.Name)
                    </dd>
                </dl>

                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn btn-danger">Eliminar</button>
                </form>
            </div>
        </div>
    </div>
</div>