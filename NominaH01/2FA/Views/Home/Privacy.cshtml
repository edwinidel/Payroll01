@{
    ViewData["Title"] = "Política de Privacidad";
}

<div class="container-fluid py-4">
    <!-- Header Section -->
    <div class="row mb-5">
        <div class="col-12">
            <div class="text-center mb-4">
                <div class="privacy-header-icon mb-3">
                    <i class="bi bi-shield-check-fill text-primary" style="font-size: 4rem;"></i>
                </div>
                <h1 class="display-4 fw-bold text-primary mb-3">Política de Privacidad</h1>
                <p class="lead text-muted mb-0">Nomina Hub - Sistema Integral de Gestión de Nóminas</p>
            </div>
        </div>
    </div>

    <!-- Last Updated -->
    <div class="row mb-5">
        <div class="col-lg-8 mx-auto">
            <div class="alert alert-info border-0 rounded-3">
                <div class="d-flex align-items-center">
                    <i class="bi bi-calendar-check me-3 fs-4"></i>
                    <div>
                        <h6 class="mb-1">Última Actualización</h6>
                        <p class="mb-0">18 de diciembre de 2025</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Content Sections -->
    <div class="row">
        <div class="col-lg-10 mx-auto">
            
            <!-- Introduction -->
            <div class="privacy-section mb-5">
                <div class="card border-0 shadow-sm rounded-3">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center mb-3">
                            <div class="privacy-icon bg-primary bg-opacity-10 rounded-circle p-3 me-3">
                                <i class="bi bi-info-circle-fill text-primary fs-5"></i>
                            </div>
                            <h2 class="h3 mb-0 text-primary">Introducción</h2>
                        </div>
                        <p class="text-muted mb-0">
                            En <strong>Nomina Hub</strong>, valoramos y respetamos su privacidad. Esta Política de Privacidad 
                            describe cómo recopilamos, utilizamos, almacenamos y protegemos su información personal y la de 
                            sus empleados al utilizar nuestro sistema integral de gestión de nóminas diseñado específicamente 
                            para empresas panameñas.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Information We Collect -->
            <div class="privacy-section mb-5">
                <div class="card border-0 shadow-sm rounded-3">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center mb-3">
                            <div class="privacy-icon bg-info bg-opacity-10 rounded-circle p-3 me-3">
                                <i class="bi bi-database-fill text-info fs-5"></i>
                            </div>
                            <h2 class="h3 mb-0 text-primary">Información que Recopilamos</h2>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <h5 class="fw-bold text-dark mb-3">Datos de la Empresa</h5>
                                <ul class="list-unstyled text-muted">
                                    <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Información corporativa</li>
                                    <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Configuraciones de nóminas</li>
                                    <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Estructuras organizacionales</li>
                                    <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Datos bancarios para depósitos</li>
                                </ul>
                            </div>
                            <div class="col-md-6">
                                <h5 class="fw-bold text-dark mb-3">Datos de Empleados</h5>
                                <ul class="list-unstyled text-muted">
                                    <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Información personal</li>
                                    <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Datos contractuales</li>
                                    <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Historial de salarios</li>
                                    <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Deducciones legales</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- How We Use Information -->
            <div class="privacy-section mb-5">
                <div class="card border-0 shadow-sm rounded-3">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center mb-3">
                            <div class="privacy-icon bg-success bg-opacity-10 rounded-circle p-3 me-3">
                                <i class="bi bi-gear-fill text-success fs-5"></i>
                            </div>
                            <h2 class="h3 mb-0 text-primary">Cómo Utilizamos su Información</h2>
                        </div>
                        <div class="row g-4">
                            <div class="col-md-4 text-center">
                                <div class="feature-item">
                                    <i class="bi bi-calculator text-primary fs-2 mb-3"></i>
                                    <h6 class="fw-bold">Cálculo de Nóminas</h6>
                                    <p class="small text-muted">Procesamiento automático de salarios y deducciones</p>
                                </div>
                            </div>
                            <div class="col-md-4 text-center">
                                <div class="feature-item">
                                    <i class="bi bi-file-earmark-text text-primary fs-2 mb-3"></i>
                                    <h6 class="fw-bold">Generación de Reportes</h6>
                                    <p class="small text-muted">Creación de comprobantes y reportes legales</p>
                                </div>
                            </div>
                            <div class="col-md-4 text-center">
                                <div class="feature-item">
                                    <i class="bi bi-bank text-primary fs-2 mb-3"></i>
                                    <h6 class="fw-bold">Depósitos Bancarios</h6>
                                    <p class="small text-muted">Procesamiento seguro de transferencias</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Data Protection -->
            <div class="privacy-section mb-5">
                <div class="card border-0 shadow-sm rounded-3">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center mb-3">
                            <div class="privacy-icon bg-warning bg-opacity-10 rounded-circle p-3 me-3">
                                <i class="bi bi-shield-lock-fill text-warning fs-5"></i>
                            </div>
                            <h2 class="h3 mb-0 text-primary">Protección de Datos</h2>
                        </div>
                        <div class="row">
                            <div class="col-lg-8">
                                <p class="text-muted mb-4">
                                    Implementamos medidas de seguridad técnicas y organizativas apropiadas para proteger 
                                    los datos personales contra el acceso no autorizado, alteración, divulgación o destrucción.
                                </p>
                                <div class="row">
                                    <div class="col-md-6">
                                        <h6 class="fw-bold text-dark mb-2">Medidas Técnicas</h6>
                                        <ul class="list-unstyled text-muted small">
                                            <li class="mb-1">• Encriptación SSL/TLS</li>
                                            <li class="mb-1">• Autenticación multifactor</li>
                                            <li class="mb-1">• Respaldos automáticos</li>
                                        </ul>
                                    </div>
                                    <div class="col-md-6">
                                        <h6 class="fw-bold text-dark mb-2">Medidas Organizacionales</h6>
                                        <ul class="list-unstyled text-muted small">
                                            <li class="mb-1">• Control de acceso por roles</li>
                                            <li class="mb-1">• Auditorías de seguridad</li>
                                            <li class="mb-1">• Capacitación del personal</li>
                                        </ul>
                                    </div>
                                </div>
                            </div>
                            <div class="col-lg-4">
                                <div class="security-badge text-center p-4 bg-light rounded-3">
                                    <i class="bi bi-award text-warning fs-1 mb-3"></i>
                                    <h6 class="fw-bold">Cumplimiento Legal</h6>
                                    <p class="small text-muted mb-0">Conforme con las regulaciones de protección de datos de Panamá</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Legal Compliance -->
            <div class="privacy-section mb-5">
                <div class="card border-0 shadow-sm rounded-3">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center mb-3">
                            <div class="privacy-icon bg-danger bg-opacity-10 rounded-circle p-3 me-3">
                                <i class="bi bi-balance-scale-fill text-danger fs-5"></i>
                            </div>
                            <h2 class="h3 mb-0 text-primary">Cumplimiento Legal</h2>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <h5 class="fw-bold text-dark mb-3">Legislación Panameña</h5>
                                <ul class="list-unstyled text-muted">
                                    <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Ley de Protección de Datos Personales</li>
                                    <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Código de Trabajo de Panamá</li>
                                    <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Regulaciones del Ministerio de Trabajo</li>
                                    <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Normas tributarias vigentes</li>
                                </ul>
                            </div>
                            <div class="col-md-6">
                                <h5 class="fw-bold text-dark mb-3">Derechos de los Empleados</h5>
                                <ul class="list-unstyled text-muted">
                                    <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Acceso a sus datos personales</li>
                                    <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Rectificación de información</li>
                                    <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Portabilidad de datos</li>
                                    <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Eliminación de datos</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Data Retention -->
            <div class="privacy-section mb-5">
                <div class="card border-0 shadow-sm rounded-3">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center mb-3">
                            <div class="privacy-icon bg-secondary bg-opacity-10 rounded-circle p-3 me-3">
                                <i class="bi bi-clock-fill text-secondary fs-5"></i>
                            </div>
                            <h2 class="h3 mb-0 text-primary">Retención de Datos</h2>
                        </div>
                        <p class="text-muted mb-3">
                            Conservamos los datos personales únicamente durante el tiempo necesario para cumplir 
                            con los propósitos establecidos en esta política y los requisitos legales aplicables.
                        </p>
                        <div class="row g-3">
                            <div class="col-md-4">
                                <div class="retention-item text-center p-3 bg-light rounded-3">
                                    <h6 class="fw-bold text-primary">Datos Activos</h6>
                                    <p class="small text-muted mb-0">Mientras mantenga una cuenta activa en el sistema</p>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="retention-item text-center p-3 bg-light rounded-3">
                                    <h6 class="fw-bold text-primary">Registros Laborales</h6>
                                    <p class="small text-muted mb-0">Según lo establecido por la ley laboral panameña</p>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="retention-item text-center p-3 bg-light rounded-3">
                                    <h6 class="fw-bold text-primary">Datos Financieros</h6>
                                    <p class="small text-muted mb-0">Período requerido por regulaciones fiscales</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Contact Information -->
            <div class="privacy-section mb-5">
                <div class="card border-0 shadow-sm rounded-3 bg-primary text-white">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center mb-3">
                            <div class="privacy-icon bg-white bg-opacity-20 rounded-circle p-3 me-3">
                                <i class="bi bi-envelope-fill fs-5"></i>
                            </div>
                            <h2 class="h3 mb-0">Contacto</h2>
                        </div>
                        <div class="row">
                            <div class="col-md-8">
                                <p class="mb-3 opacity-90">
                                    Si tiene preguntas sobre esta Política de Privacidad o sobre cómo manejamos 
                                    sus datos personales, no dude en contactarnos:
                                </p>
                                <div class="contact-info">
                                    <div class="d-flex align-items-center mb-2">
                                        <i class="bi bi-envelope me-3"></i>
                                        <span>privacidad@nominahub.com</span>
                                    </div>
                                    <div class="d-flex align-items-center mb-2">
                                        <i class="bi bi-telephone me-3"></i>
                                        <span>+507 XXXX-XXXX</span>
                                    </div>
                                    <div class="d-flex align-items-center">
                                        <i class="bi bi-geo-alt me-3"></i>
                                        <span>Ciudad de Panamá, Panamá</span>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4 text-center">
                                <div class="contact-illustration">
                                    <i class="bi bi-headset" style="font-size: 4rem; opacity: 0.8;"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Footer Note -->
            <div class="text-center">
                <p class="text-muted small">
                    Esta política puede ser actualizada periódicamente. Le notificaremos sobre cualquier 
                    cambio significativo a través del sistema o por correo electrónico.
                </p>
            </div>

        </div>
    </div>
</div>

<style>
    .privacy-header-icon {
        animation: fadeInDown 1s ease-out;
    }

    .privacy-section {
        animation: fadeInUp 0.8s ease-out;
    }

    .privacy-icon {
        width: 60px;
        height: 60px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .feature-item {
        transition: transform 0.3s ease;
    }

    .feature-item:hover {
        transform: translateY(-5px);
    }

    .retention-item {
        transition: all 0.3s ease;
        border: 1px solid rgba(0,0,0,0.05);
    }

    .retention-item:hover {
        background-color: var(--bs-primary) !important;
        color: white !important;
        transform: translateY(-3px);
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    }

    .retention-item:hover h6,
    .retention-item:hover p {
        color: inherit !important;
    }

    .security-badge {
        border: 2px solid rgba(255, 193, 7, 0.2);
    }

    .contact-info i {
        width: 20px;
        text-align: center;
    }

    @@keyframes fadeInDown {
        from {
            opacity: 0;
            transform: translateY(-30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Responsive adjustments */
    @@media (max-width: 768px) {
        .privacy-header-icon i {
            font-size: 3rem !important;
        }
        
        .display-4 {
            font-size: 2.5rem;
        }
        
        .feature-item {
            margin-bottom: 2rem;
        }
    }
</style>
