@using Microsoft.AspNetCore.Identity
@using _2FA.Data.Entities
@inject SignInManager<AppUser> SignInManager
@inject UserManager<AppUser> UserManager

@{
    ViewData["Title"] = "Home Page";
}

@if (SignInManager.IsSignedIn(User))
{
    <partial name="_HomeCard" />
}
else
{
    <!-- Welcome Page for Non-Logged-In Users -->
    <div class="text-center my-3">
        <h1 class="display-3 fw-bold text-primary mb-3">Bienvenido a Nomina Hub</h1>
        <p class="lead text-muted">Sistema integral de gestión de nóminas diseñado para empresas panameñas</p>
    </div>
    
    <!-- Hero Section -->
    <div class="hero-section bg-light mb-5">
        <div class="container">
            <div class="row align-items-center py-5">
                <div class="col-lg-8">
                    <h2 class="display-6 fw-bold text-dark mb-4">Automatiza y simplifica la gestión de nóminas</h2>
                    <p class="lead text-muted mb-4">
                        Administra empleados, calcula salarios, genera reportes y mucho más de manera eficiente y segura.
                        Diseñado específicamente para cumplir con las regulaciones laborales de Panamá.
                    </p>
                    
                    <!-- Key Benefits -->
                    <div class="row mb-4">
                        <div class="col-md-6 mb-3">
                            <div class="d-flex align-items-center">
                                <i class="bi bi-speedometer2 text-primary fs-4 me-3"></i>
                                <div>
                                    <h6 class="mb-1">Ahorra tiempo valioso</h6>
                                    <small class="text-muted">Reduce el tiempo de procesamiento hasta en un 80%</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <div class="d-flex align-items-center">
                                <i class="bi bi-shield-check text-primary fs-4 me-3"></i>
                                <div>
                                    <h6 class="mb-1">100% Conforme con la Ley</h6>
                                    <small class="text-muted">Cálculos automáticos de deducciones legales</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <div class="d-flex align-items-center">
                                <i class="bi bi-graph-up text-primary fs-4 me-3"></i>
                                <div>
                                    <h6 class="mb-1">Reportes detallados</h6>
                                    <small class="text-muted">Análisis y reportes en tiempo real</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <div class="d-flex align-items-center">
                                <i class="bi bi-cloud-upload text-primary fs-4 me-3"></i>
                                <div>
                                    <h6 class="mb-1">Acceso desde cualquier lugar</h6>
                                    <small class="text-muted">Interfaz web completamente responsive</small>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex flex-column flex-sm-row gap-3">
                        <a href="/Identity/Account/Login" class="btn btn-primary btn-lg px-5">Comenzar Ahora</a>
                        <a href="#features" class="btn btn-outline-primary btn-lg px-5">Conocer Más</a>
                    </div>
                </div>
                <div class="col-lg-4 text-center">
                    <img src="~/img/logo1.png" alt="2FA Logo" class="img-fluid" style="max-width: 400px;" />
                </div>
            </div>
        </div>
    </div>

    <!-- Features Section -->
    <section id="features" class="py-5">
        <div class="container">
            <div class="row text-center mb-5">
                <div class="col-lg-8 mx-auto">
                    <h2 class="display-6 fw-bold mb-3">¿Qué puedes hacer con Nomina Hub?</h2>
                    <p class="lead text-muted">
                        Descubre todas las funcionalidades que harán de la gestión de nóminas una tarea simple y eficiente
                    </p>
                </div>
            </div>

            <div class="row g-4">
                <div class="col-lg-4 col-md-6">
                    <div class="feature-card h-100 p-4 bg-white rounded-3 shadow-sm border">
                        <div class="feature-icon mb-3">
                            <i class="bi bi-people-fill text-primary fs-1"></i>
                        </div>
                        <h5 class="fw-bold mb-3">Gestión Completa de Empleados</h5>
                        <p class="text-muted">
                            Administra la información completa de tus empleados, incluyendo datos personales,
                            contractuales y de contacto en un solo lugar.
                        </p>
                        <ul class="list-unstyled">
                            <li><i class="bi bi-check text-success me-2"></i>Registro de datos personales</li>
                            <li><i class="bi bi-check text-success me-2"></i>Historial de empleados</li>
                            <li><i class="bi bi-check text-success me-2"></i>Gestión de departamentos</li>
                        </ul>
                    </div>
                </div>

                <div class="col-lg-4 col-md-6">
                    <div class="feature-card h-100 p-4 bg-white rounded-3 shadow-sm border">
                        <div class="feature-icon mb-3">
                            <i class="bi bi-calculator text-primary fs-1"></i>
                        </div>
                        <h5 class="fw-bold mb-3">Cálculos Automáticos</h5>
                        <p class="text-muted">
                            Calcula automáticamente salarios, horas extras, bonificaciones y deducciones
                            según la legislación laboral panameña.
                        </p>
                        <ul class="list-unstyled">
                            <li><i class="bi bi-check text-success me-2"></i>Cálculo de salarios base</li>
                            <li><i class="bi bi-check text-success me-2"></i>Horas extras y bonificaciones</li>
                            <li><i class="bi bi-check text-success me-2"></i>Deducciones legales automáticas</li>
                        </ul>
                    </div>
                </div>

                <div class="col-lg-4 col-md-6">
                    <div class="feature-card h-100 p-4 bg-white rounded-3 shadow-sm border">
                        <div class="feature-icon mb-3">
                            <i class="bi bi-file-earmark-text text-primary fs-1"></i>
                        </div>
                        <h5 class="fw-bold mb-3">Reportes Profesionales</h5>
                        <p class="text-muted">
                            Genera reportes detallados en PDF para gestión interna, declaraciones
                            gubernamentales y cumplimiento legal.
                        </p>
                        <ul class="list-unstyled">
                            <li><i class="bi bi-check text-success me-2"></i>Recibos de pago digitales</li>
                            <li><i class="bi bi-check text-success me-2"></i>Reportes de nómina</li>
                            <li><i class="bi bi-check text-success me-2"></i>Exportación a Excel</li>
                        </ul>
                    </div>
                </div>

                <div class="col-lg-4 col-md-6">
                    <div class="feature-card h-100 p-4 bg-white rounded-3 shadow-sm border">
                        <div class="feature-icon mb-3">
                            <i class="bi bi-building text-primary fs-1"></i>
                        </div>
                        <h5 class="fw-bold mb-3">Gestión Multi-Empresa</h5>
                        <p class="text-muted">
                            Perfecto para organizaciones con múltiples empresas o sucursales.
                            Cambia entre empresas de forma instantánea.
                        </p>
                        <ul class="list-unstyled">
                            <li><i class="bi bi-check text-success me-2"></i>Múltiples empresas</li>
                            <li><i class="bi bi-check text-success me-2"></i>Centros de costo</li>
                            <li><i class="bi bi-check text-success me-2"></i>Departamentos y divisiones</li>
                        </ul>
                    </div>
                </div>

                <div class="col-lg-4 col-md-6">
                    <div class="feature-card h-100 p-4 bg-white rounded-3 shadow-sm border">
                        <div class="feature-icon mb-3">
                            <i class="bi bi-clock-history text-primary fs-1"></i>
                        </div>
                        <h5 class="fw-bold mb-3">Control de Horarios</h5>
                        <p class="text-muted">
                            Administra turnos, horarios de trabajo, horas extras y planes de descanso
                            para optimizar la productividad.
                        </p>
                        <ul class="list-unstyled">
                            <li><i class="bi bi-check text-success me-2"></i>Programación de turnos</li>
                            <li><i class="bi bi-check text-success me-2"></i>Cálculo automático de horas</li>
                            <li><i class="bi bi-check text-success me-2"></i>Calendario integrado</li>
                        </ul>
                    </div>
                </div>

                <div class="col-lg-4 col-md-6">
                    <div class="feature-card h-100 p-4 bg-white rounded-3 shadow-sm border">
                        <div class="feature-icon mb-3">
                            <i class="bi bi-patch-check-fill text-primary fs-1"></i>
                        </div>
                        <h5 class="fw-bold mb-3">Cumplimiento Legal</h5>
                        <p class="text-muted">
                            Mantén tu empresa conforme con todas las regulaciones laborales
                            y fiscales de Panamá.
                        </p>
                        <ul class="list-unstyled">
                            <li><i class="bi bi-check text-success me-2"></i>Ley de trabajo panameña</li>
                            <li><i class="bi bi-check text-success me-2"></i>Deducciones automáticas</li>
                            <li><i class="bi bi-check text-success me-2"></i>Reportes gubernamentales</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Statistics Section -->
