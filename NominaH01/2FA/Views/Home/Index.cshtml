    <!-- Why Choose Us Section -->
    <section class="py-5">
        <div class="container">
            <div class="row">
                <div class="col-lg-8 mx-auto text-center mb-5">
                    <h2 class="display-6 fw-bold mb-3">¿Por qué elegir Nomina Hub?</h2>
                    <p class="lead text-muted">
                        Somos la solución más completa y confiable para la gestión de nóminas en Panamá
                    </p>
                </div>
            </div>
            <div class="row g-4">
                <div class="col-lg-4">
                    <div class="text-center">
                        <div class="why-icon mb-3">
                            <i class="bi bi-lightning-fill text-warning fs-1"></i>
                        </div>
                        <h5 class="fw-bold mb-3">Fácil de Usar</h5>
                        <p class="text-muted">
                            Interfaz intuitiva diseñada para que cualquier usuario pueda comenzar
                            a gestionar nóminas sin capacitación técnica.
                        </p>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="text-center">
                        <div class="why-icon mb-3">
                            <i class="bi bi-headset text-info fs-1"></i>
                        </div>
                        <h5 class="fw-bold mb-3">Soporte Especializado</h5>
                        <p class="text-muted">
                            Equipo de soporte especializado en nóminas y legislación laboral
                            panameña disponible para ayudarte.
                        </p>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="text-center">
                        <div class="why-icon mb-3">
                            <i class="bi bi-safe text-success fs-1"></i>
                        </div>
                        <h5 class="fw-bold mb-3">Datos Seguros</h5>
                        <p class="text-muted">
                            Tu información está protegida con los más altos estándares de seguridad
                            y respaldos automáticos diarios.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Call to Action -->
    <section class="py-5 bg-light">
        <div class="container">
            <div class="row justify-content-center text-center">
                <div class="col-lg-8">
                    <h2 class="display-6 fw-bold mb-3">¿Listo para simplificar la gestión de nóminas?</h2>
                    <p class="lead text-muted mb-4">
                        Únete a cientos de empresas panameñas que ya confían en Nomina Hub
                        para gestionar sus nóminas de manera eficiente y segura.
                    </p>
                    <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center">
                        <a href="/Identity/Account/Login" class="btn btn-primary btn-lg px-5">
                            <i class="bi bi-box-arrow-in-right me-2"></i>
                            Comenzar Ahora
                        </a>
                        <button type="button" class="btn btn-outline-primary btn-lg px-5" data-bs-toggle="modal" data-bs-target="#contactModal">
                            <i class="bi bi-envelope me-2"></i>
                            Solicitar Demo
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <style>
        .hero-section {
            background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
            border-radius: 15px;
        }
        .hero-section .display-6 {
            color: #2c3e50;
        }
        .hero-section .lead {
            font-size: 1.1rem;
            line-height: 1.6;
        }
        .hero-section .btn {
            border-radius: 50px;
            padding: 12px 30px;
            font-weight: 600;
            transition: all 0.3s ease;
            border: none;
        }
        .hero-section .btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(0,0,0,0.2);
        }
        .hero-section .btn-outline-primary:hover {
            background-color: #0d6efd;
            border-color: #0d6efd;
        }

        /* Feature Cards */
        .feature-card {
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            border: 1px solid #e9ecef !important;
        }
        .feature-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 25px rgba(0,0,0,0.15) !important;
        }
        .feature-icon {
            text-align: center;
        }

        /* Statistics Section */
        .bg-primary {
            background: linear-gradient(135deg, #0d6efd 0%, #0b5ed7 100%) !important;
        }
        .stat-item {
            padding: 20px;
        }
        .stat-item i {
            opacity: 0.8;
        }
        .stat-item h3 {
            font-size: 2.5rem;
            margin-bottom: 10px;
        }

        /* Why Choose Us Section */
        .why-icon {
            text-align: center;
            padding: 20px;
        }
        .why-icon i {
            opacity: 0.8;
        }

        /* Call to Action Section */
        .cta-section {
            background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
        }

        /* Responsive Design */
        @@media (max-width: 768px) {
            .hero-section .display-6 {
                font-size: 2rem;
            }
            .hero-section .row {
                text-align: center;
            }
            .stat-item h3 {
                font-size: 2rem;
            }
            .feature-card {
                margin-bottom: 2rem;
            }
        }

        /* Smooth Scrolling */
        html {
            scroll-behavior: smooth;
        }

        /* Animation for elements coming into view */
        .feature-card, .stat-item, .why-icon {
            opacity: 0;
            animation: fadeInUp 0.6s ease forwards;
        }

        .feature-card:nth-child(1) { animation-delay: 0.1s; }
        .feature-card:nth-child(2) { animation-delay: 0.2s; }
        .feature-card:nth-child(3) { animation-delay: 0.3s; }
        .feature-card:nth-child(4) { animation-delay: 0.4s; }
        .feature-card:nth-child(5) { animation-delay: 0.5s; }
        .feature-card:nth-child(6) { animation-delay: 0.6s; }

        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
}
