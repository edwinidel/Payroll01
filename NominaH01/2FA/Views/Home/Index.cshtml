    <section class="py-5 bg-primary text-white">
        <div class="container">
            <div class="row text-center">
                <div class="col-lg-3 col-md-6 mb-4">
                    <div class="stat-item">
                        <i class="bi bi-people fs-1 mb-3"></i>
                        <h3 class="fw-bold mb-2">1000+</h3>
