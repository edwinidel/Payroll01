@using Microsoft.AspNetCore.Identity
@using _2FA.Data.Entities
@inject SignInManager<AppUser> SignInManager
@inject UserManager<AppUser> UserManager

<div class="home-flip-cards">
    <div class="flip-cards-row">
        <div class="flip-card-container">
            <div class="flip-card-wrapper">
                <div class="flip-card">
                    <div class="flip-card-inner">
                        <div class="flip-card-front">
                            <i class="bi bi-calculator"></i>
                            <h5>Administración</h5>
                        </div>
                        <div class="flip-card-back">
                            <a asp-controller="Home" asp-action="Administration" class="btn btn-primary">Acceder</a>
                            <p>Manejo de Empleados, Nóminas, etc. </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="flip-card-container">
            <div class="flip-card-wrapper">
                <div class="flip-card">
                    <div class="flip-card-inner">
                        <div class="flip-card-front">
                            <i class="bi bi-people"></i>
                            <h5>Informes</h5>
                        </div>
                        <div class="flip-card-back">
                            <a href="#" class="btn btn-primary">Acceder</a>
                            <p>Generación de Reportes varios</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="flip-card-container">
            <div class="flip-card-wrapper">
                <div class="flip-card">
                    <div class="flip-card-inner">
                        <div class="flip-card-front">
                            <i class="bi bi-building"></i>
                            <h5>Configuración</h5>
                        </div>
                        <div class="flip-card-back">
                            <a href="/Home/Configurations" class="btn btn-primary">Acceder</a>
                            <p>Configuraciones varias</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="flip-card-container">
            <div class="flip-card-wrapper">
                <div class="flip-card">
                    <div class="flip-card-inner">
                        <div class="flip-card-front">
                            <i class="bi bi-bank"></i>
                            <h5>Cambiar de Compañía</h5>
                        </div>
                        <div class="flip-card-back">
                            <a href="/Home/SwitchCompany" class="btn btn-primary">Ingresar</a>
                            <p>Abandonar la compañía actual para ingresar en otra</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
