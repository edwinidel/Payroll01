@model _2FA.Data.Entities.CreditorEntity

@{
    ViewData["Title"] = "Create";
}

<div style="text-align: center;">
    <h2>Nueva Acreedor</h2>
</div>

<div class="m-0 row justify-content-center">
    <div class="col-md-5">
        <div class="card">
            <card-header>
                <div class="p-3">
                </div>
            </card-header>
            <div class="card-body">
                <div class="row">
                    <div>
                        <form asp-action="Create">
                            <!-- Alerta de errores de validación -->
                            @if (!ViewData.ModelState.IsValid)
                            {
                                <div class="alert alert-warning alert-dismissible fade show" role="alert">
                                    <i class="bi bi-exclamation-triangle-fill"></i>
                                    <strong>¡Atención!</strong> Se encontraron errores de validación. Por favor, revise el listado de errores que aparece al final del formulario.
                                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                                </div>
                            }

                            <div class="form-group">
                                <a title="Regresar" class="btn-action" asp-action="Index"><i class="fa-solid fa-left-long"></i></a>
                                <button title="Guardar" class="btn-action" type="submit"><i class="fa-solid fa-floppy-disk"></i></button>
                            </div>
                            <div class="row">
                                <div class="col-md-2">
                                    <div class="form-group">
                                        <label asp-for="Code" class="control-label"></label>
                                        <input asp-for="Code" class="form-control" />
                                        <span asp-validation-for="Code" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-md-9">
                                    <div class="form-group">
                                        <label asp-for="Name" class="control-label"></label>
                                        <input asp-for="Name" class="form-control" />
                                        <span asp-validation-for="Name" class="text-danger"></span>
                                    </div>
                                </div>
                                <div>
                                    <div class="col-md-1">
                                        <div style="text-align: center;">
                                            <label asp-for="IsActive" class="control-label"></label>
                                        </div>
                                        <div class="form-check form-switch d-flex justify-content-center align-items-center" style="min-height: 50px;">
                                            <input class="form-check-input" asp-for="IsActive" type="checkbox" id="flexSwitchCheckDefault" style="font-size: 20px;">
                                            <label class="form-check-label" for="flexSwitchCheckDefault"></label>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-3">
                                    <div class="form-group">
                                        <label asp-for="RUC" class="control-label"></label>
                                        <input asp-for="RUC" class="form-control" />
                                        <span asp-validation-for="RUC" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="form-group">
                                        <label asp-for="Dv" class="control-label"></label>
                                        <input asp-for="Dv" class="form-control" />
                                        <span asp-validation-for="Dv" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="form-group">
                                        <label asp-for="FixedPhone" class="control-label"></label>
                                        <input asp-for="FixedPhone" class="form-control" />
                                        <span asp-validation-for="FixedPhone" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="form-group">
                                        <label asp-for="CellPhone" class="control-label"></label>
                                        <input asp-for="CellPhone" class="form-control" />
                                        <span asp-validation-for="CellPhone" class="text-danger"></span>
                                    </div>
                                </div>
                            </div>

                            <!-- Listado de errores de validación -->
                            @if (!ViewData.ModelState.IsValid)
                            {
                                <div class="mt-3">
                                    <div class="card border-danger">
                                        <div class="card-header bg-danger text-white">
                                            <h5 class="mb-0">
                                                <i class="bi bi-exclamation-circle"></i>
                                                Errores de Validación Detectados
                                            </h5>
                                        </div>
                                        <div class="card-body">
                                            <p class="card-text">Por favor, corrija los siguientes errores antes de guardar:</p>
                                            <div asp-validation-summary="All" class="text-danger"></div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </form>
                    </div>
                </div>
            </div>
        </div>      
    <div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
