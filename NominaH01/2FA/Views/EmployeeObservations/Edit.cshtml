@model _2FA.Data.Entities.EmployeeObservationEntity

@{
    ViewData["Title"] = "Edit";
}

<div style="text-align: center;">
    <h2>Editar Observaciones de Empleado</h2>
</div>

<div class="m-0 row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <card-header>
                <div class="p-3">
                </div>
            </card-header>
            <div class="card-body">
                <div class="row">
                    <div>
                        <form asp-action="Edit">
                            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                            <input type="hidden" asp-for="Id" />
                            <input type="hidden" asp-for="Created" />
                            <input type="hidden" asp-for="CreatedBy" />

                            <div class="form-group">
                                <a title="Regresar" class="btn-action" asp-action="Index"><i class="fa-solid fa-left-long"></i></a>
                                <button title="Guardar" class="btn-action" type="submit"><i class="fa-solid fa-floppy-disk"></i></button>
                            </div>
                            <br>

                            <div class="row">
                                <div class="col-md-8">
                                    <div class="form-group">
                                        <label asp-for="EmployeeId" class="control-label"></label>
                                        <input asp-for="EmployeeId" class="form-control" />
                                        <span asp-validation-for="EmployeeId" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label asp-for="ObservationTypeId" class="control-label"></label>
                                        <input asp-for="ObservationTypeId" class="form-control" />
                                        <span asp-validation-for="ObservationTypeId" class="text-danger"></span>
                                    </div>
                                </div>
                            </div>
                            <div class="form-group">
                                <label asp-for="Observations" class="control-label"></label>
                                <textarea asp-for="Observations" class="form-control" rows="5" placeholder="Anote aquí su observación."></textarea>
                                <span asp-validation-for="Observations" class="text-danger"></span>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
