@model _2FA.Data.Entities.CompanyEntity

@{
    ViewData["Title"] = "Details";
}

<div style="text-align: center;">
    <h2>Detalle de la Compañía</h2>
</div>

<div class="m-0 row justify-content-center">
    <div class="col-md-8">
        <div class="card">
            <card-header>
                <div class="p-3">
                    <a title="Editar registro" class="btn-action" asp-action="Edit" asp-route-id="@Model?.Id"><i class="fa-solid fa-pen-to-square"></i></a>
                    &nbsp;
                    <a title="Regresar" class="btn-action" asp-action="Index"><i class="fa-solid fa-left-long"></i></a>
                </div>
            </card-header>
            <div class="card-body">
                <hr />
                <div class="row">
                    <div class="col-md-6">
                        <dl class="row">
                            <dt class = "col-sm-4">
                                @Html.DisplayNameFor(model => model.Name)
                            </dt>
                            <dd class = "col-sm-8">
                                @Html.DisplayFor(model => model.Name)
                            </dd>
                            <dt class = "col-sm-4">
                                @Html.DisplayNameFor(model => model.FixedPhone)
                            </dt>
                            <dd class = "col-sm-8">
                                @Html.DisplayFor(model => model.FixedPhone)
                            </dd>
                            <dt class = "col-sm-4">
                                @Html.DisplayNameFor(model => model.CellPhone)
                            </dt>
                            <dd class = "col-sm-8">
                                @Html.DisplayFor(model => model.CellPhone)
                            </dd>
                            <dt class = "col-sm-4">
                                @Html.DisplayNameFor(model => model.CountryId)
                            </dt>
                            <dd class = "col-sm-8">
                                @Html.DisplayFor(model => model.Country.Name_es)
                            </dd>
                            <dt class = "col-sm-4">
                                @Html.DisplayNameFor(model => model.StateId)
                            </dt>
                            <dd class = "col-sm-8">
                                @Html.DisplayFor(model => model.State.Name)
                            </dd>
                            <dt class = "col-sm-4">
                                @Html.DisplayNameFor(model => model.CityId)
                            </dt>
                            <dd class = "col-sm-8">
                                @Html.DisplayFor(model => model.City.Name)
                            </dd>
                            <dt class = "col-sm-4">
                                @Html.DisplayNameFor(model => model.Address)
                            </dt>
                            <dd class = "col-sm-8">
                                @Html.DisplayFor(model => model.Address)
                            </dd>
                            <dt class = "col-sm-4">
                                @Html.DisplayNameFor(model => model.Email)
                            </dt>
                            <dd class = "col-sm-8">
                                @Html.DisplayFor(model => model.Email)
                            </dd>
                            <dt class = "col-sm-4">
                                @Html.DisplayNameFor(model => model.Ruc)
                            </dt>
                            <dd class = "col-sm-8">
                                @Html.DisplayFor(model => model.Ruc)
                            </dd>
                            <dt class = "col-sm-4">
                                @Html.DisplayNameFor(model => model.Dv)
                            </dt>
                            <dd class = "col-sm-8">
                                @Html.DisplayFor(model => model.Dv)
                            </dd>
                            <dt class = "col-sm-4">
                                @Html.DisplayNameFor(model => model.IsActive)
                            </dt>
                            <dd class = "col-sm-8">
                                @if(Model.IsActive)
                                {
                                    <span class="badge bg-success">Sí</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">No</span>
                                }
                            </dd>
                        </dl>
                    </div>
                    <div class="col-md-6">
                        <dl class="row">
                            <dt class = "col-sm-4">
                                @Html.DisplayNameFor(model => model.BusinessGroup)
                            </dt>
                            <dd class = "col-sm-8">
                                @Html.DisplayFor(model => model.BusinessGroup.Name)
                            </dd>
                            <dt class = "col-sm-4">
                                @Html.DisplayNameFor(model => model.Created)
                            </dt>
                            <dd class = "col-sm-8">
                                @Html.DisplayFor(model => model.Created)
                            </dd>
                            <dt class = "col-sm-4">
                                @Html.DisplayNameFor(model => model.CreatedBy)
                            </dt>
                            <dd class = "col-sm-8">
                                @Html.DisplayFor(model => model.CreatedBy)
                            </dd>
                            <dt class = "col-sm-4">
                                @Html.DisplayNameFor(model => model.Modified)
                            </dt>
                            <dd class = "col-sm-8">
                                @Html.DisplayFor(model => model.Modified)
                            </dd>
                            <dt class = "col-sm-4">
                                @Html.DisplayNameFor(model => model.ModifiedBy)
                            </dt>
                            <dd class = "col-sm-8">
                                @Html.DisplayFor(model => model.ModifiedBy)
                            </dd>
                            <dt class = "col-sm-4">
                                @Html.DisplayNameFor(model => model.Deleted)
                            </dt>
                            <dd class = "col-sm-8">
                                @Html.DisplayFor(model => model.Deleted)
                            </dd>
                            <dt class = "col-sm-4">
                                @Html.DisplayNameFor(model => model.DeletedBy)
                            </dt>
                            <dd class = "col-sm-8">
                                @Html.DisplayFor(model => model.DeletedBy)
                            </dd>
                            <dt class = "col-sm-4">
                                @Html.DisplayNameFor(model => model.IsDeleted)
                            </dt>
                            <dd class = "col-sm-8">
                                @if(Model.IsDeleted)
                                {
                                    <span class="badge bg-danger">Sí</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">No</span>
                                }
                            </dd>
                        </dl>
                    </div>
                </div>

                <div style="text-align: center;">
                    <h4>Estadísticas de Empleados</h4>
                </div>
                <div class="col-md-12">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">Empleados por Estado</h5>
                            @if (ViewData["EmployeeStats"] != null)
                            {
                                var employeeStats = (IEnumerable<dynamic>)ViewData["EmployeeStats"];
                                if (employeeStats.Any())
                                {
                                    <div class="row">
                                        @foreach (var stat in employeeStats)
                                        {
                                            <div class="col-md-3 mb-3">
                                                <div class="card text-center">
                                                    <div class="card-body">
                                                        <h5 class="card-title">@stat.Count</h5>
                                                        <p class="card-text">@stat.Status</p>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <p>No hay empleados registrados en esta compañía.</p>
                                }
                            }
                            else
                            {
                                <p>No se pudieron cargar las estadísticas de empleados.</p>
                            }
                        </div>
                    </div>
                </div>

                <div style="text-align: center;">
                    <h4>Detalle de Configuraciones</h4>
                </div>
                <div class="col-md-12">
                    <dl class="row">
                        <dt class = "col-sm-4">
                            @Html.DisplayNameFor(model => model.PaymentBankId)
                        </dt>
                        <dd class = "col-sm-8">
                            @Html.DisplayFor(model => model.PaymentBank.Name)
                        </dd>
                    </dl>
                </div>
                <div>
                    <p>Vouchers seleccionados por tipo de planilla</p>  
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Tipo de Planilla</th>
                                <th>Formato de Voucher</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.PayrollVoucherFormats != null && Model.PayrollVoucherFormats.Any())
                            {
                                foreach (var config in Model.PayrollVoucherFormats)
                                {
                                    <tr>
                                        <td>@config.PayrollType?.Name</td>
                                        <td>@config.Name</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="2">No hay configuraciones de vouchers disponibles.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
