@model _2FA.Data.Entities.CompanyEntity

<div class="row">
    <div class="col-md-10">
        <div class="form-group">
            <label asp-for="Name" class="control-label"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>
    </div>
    <div class="col-md-2">
        <div style="text-align: center;">
            <label asp-for="IsActive" class="control-label"></label>
        </div>
        <div class="form-check form-switch d-flex justify-content-center align-items-center" style="min-height: 50px;">
            <input class="form-check-input" asp-for="IsActive" type="checkbox" id="flexSwitchCheckDefault" style="font-size: 20px;">
            <label class="form-check-label" for="flexSwitchCheckDefault"></label>
        </div>
    </div>
</div>
<div class="row">
    <div class="col-md-6">
        <div class="form-group">
            <label asp-for="BusinessGroupId" class="control-label"></label>
            <select asp-for="BusinessGroupId" class="form-control" asp-items="ViewBag.BusinessGroupId"></select>
            <span asp-validation-for="BusinessGroupId" class="text-danger"></span>
        </div>
    </div>
    <div class="col-md-3">
        <div class="form-group">
            <label asp-for="FixedPhone" class="control-label"></label>
            <input asp-for="FixedPhone" class="form-control" />
            <span asp-validation-for="FixedPhone" class="text-danger"></span>
        </div>
    </div>
    <div class="col-md-3">
        <div class="form-group">
            <label asp-for="CellPhone" class="control-label"></label>
            <input asp-for="CellPhone" class="form-control" />
            <span asp-validation-for="CellPhone" class="text-danger"></span>
        </div>
    </div>
</div>
<div class="row">
    <div class="col-md-4">
        <div class="form-group">
            <label asp-for="CountryId" class="control-label"></label>
            <select asp-for="CountryId" class ="form-control" asp-items="ViewBag.CountriesId"></select>
            <span asp-validation-for="CountryId" class="text-danger"></span>
        </div>
    </div>
    <div class="col-md-4">
        <div class="form-group">
            <label asp-for="StateId" class="control-label"></label>
            <select asp-for="StateId" class ="form-control" asp-items="ViewBag.StatesId"></select>
            <span asp-validation-for="StateId" class="text-danger"></span>
        </div>
    </div>
    <div class="col-md-4">
        <div class="form-group">
            <label asp-for="CityId" class="control-label"></label>
            <select asp-for="CityId" class ="form-control" asp-items="ViewBag.CitiesId"></select>
            <span asp-validation-for="CityId" class="text-danger"></span>
        </div>
    </div>
</div>

<div class="form-group col-md-12">
    <label asp-for="Address" class="control-label"></label>
    <input asp-for="Address" class="form-control" />
    <span asp-validation-for="Address" class="text-danger"></span>
</div>
<div class="row">
    <div class="col-md-6">
        <div class="form-group">
            <label asp-for="Email" class="control-label"></label>
            <input asp-for="Email" class="form-control" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>
    </div>
    <div class="col-md-4">
        <div class="form-group">
            <label asp-for="Ruc" class="control-label"></label>
            <input asp-for="Ruc" class="form-control" />
            <span asp-validation-for="Ruc" class="text-danger"></span>
        </div>
    </div>
    <div class="col-md-2">
        <div class="form-group">
            <label asp-for="Dv" class="control-label"></label>
            <input asp-for="Dv" class="form-control" />
            <span asp-validation-for="Dv" class="text-danger"></span>
        </div>
    </div>
</div>
<hr />

<div style="text-align: center;">
    <h3>Configuraciones Adicionales</h3>
</div>

<div class="row">
    <div class="col-md-4">
        <div class="form-group">
            <label asp-for="PaymentBankId" class="control-label"></label>
        </div>
    </div>
    <div class="col-md-8">
            <select asp-for="PaymentBankId" class="form-control" asp-items="ViewBag.PaymentBankId">
                <option value="">Seleccione un banco</option>
            </select>
            <span asp-validation-for="PaymentBankId" class="text-danger"></span>
    </div>
</div>
<br />
<div class="row">
    <div class="col-md-12">
        <h4>Configuración de Vouchers por Tipo de Planilla</h4>

        <!-- Formulario para agregar nueva configuración -->
        <div class="row mb-3">
            <div class="col-md-4">
                <label>Tipo de Planilla</label>
                <select id="payrollTypeSelect" class="form-control">
                    <option value="">Seleccione tipo de planilla</option>
                    @if (ViewBag.PayrollTypes != null)
                    {
                        foreach (var payrollType in (IEnumerable<dynamic>)ViewBag.PayrollTypes)
                        {
                            <option value="@payrollType.Id">@payrollType.Name</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-4">
                <label>Formato de Voucher</label>
                <select id="voucherFormatSelect" class="form-control">
                    <option value="">Seleccione formato de voucher</option>
                    @if (ViewBag.VoucherFormats != null)
                    {
                        foreach (var format in (IEnumerable<dynamic>)ViewBag.VoucherFormats)
                        {
                            <option value="@format.Id">@format.Name</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-4 d-flex align-items-end">
                <button type="button" id="addVoucherConfig" class="btn btn-primary">Agregar Configuración</button>
            </div>
        </div>

        <!-- Tabla de configuraciones existentes -->
        <table class="table table-striped" id="voucherConfigTable">
            <thead>
                <tr>
                    <th>Tipo de Planilla</th>
                    <th>Formato de Voucher</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.PayrollVoucherFormats != null)
                {
                    foreach (var voucherFormat in Model.PayrollVoucherFormats)
                    {
                        <tr data-payroll-type-id="@voucherFormat.PayrollTypeId" data-voucher-format-id="@voucherFormat.Id">
                            <td>@voucherFormat.PayrollType?.Name</td>
                            <td>@voucherFormat.Name</td>
                            <td>
                                <button type="button" class="btn btn-danger btn-sm remove-voucher-config">Eliminar</button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<script>
    document.getElementById('addVoucherConfig').addEventListener('click', function() {
        const payrollTypeId = document.getElementById('payrollTypeSelect').value;
        const voucherFormatId = document.getElementById('voucherFormatSelect').value;

        if (!payrollTypeId || !voucherFormatId) {
            alert('Por favor seleccione tanto el tipo de planilla como el formato de voucher.');
            return;
        }

        // Verificar si ya existe una configuración para este tipo de planilla
        const existingRow = document.querySelector(`#voucherConfigTable tbody tr[data-payroll-type-id="${payrollTypeId}"]`);
        if (existingRow) {
            alert('Ya existe una configuración para este tipo de planilla.');
            return;
        }

        // Aquí puedes agregar lógica para enviar al servidor o actualizar la tabla
        // Por ahora, solo actualizamos la tabla visualmente
        const payrollTypeText = document.getElementById('payrollTypeSelect').options[document.getElementById('payrollTypeSelect').selectedIndex].text;
        const voucherFormatText = document.getElementById('voucherFormatSelect').options[document.getElementById('voucherFormatSelect').selectedIndex].text;

        const tbody = document.querySelector('#voucherConfigTable tbody');
        const newRow = document.createElement('tr');
        newRow.setAttribute('data-payroll-type-id', payrollTypeId);
        newRow.setAttribute('data-voucher-format-id', voucherFormatId);
        newRow.innerHTML = `
            <td>${payrollTypeText}</td>
            <td>${voucherFormatText}</td>
            <td><button type="button" class="btn btn-danger btn-sm remove-voucher-config">Eliminar</button></td>
        `;
        tbody.appendChild(newRow);

        // Limpiar selecciones
        document.getElementById('payrollTypeSelect').value = '';
        document.getElementById('voucherFormatSelect').value = '';

        // Actualizar hidden inputs
        updateHiddenInputs();
    });

    // Event listener para eliminar configuraciones
    document.addEventListener('click', function(e) {
        if (e.target.classList.contains('remove-voucher-config')) {
            e.target.closest('tr').remove();
            // Actualizar hidden inputs después de eliminar
            updateHiddenInputs();
        }
    });

    // Función para actualizar los hidden inputs
    function updateHiddenInputs() {
        const container = document.getElementById('voucherFormatsContainer');
        container.innerHTML = ''; // Limpiar contenedor

        const rows = document.querySelectorAll('#voucherConfigTable tbody tr');
        rows.forEach((row, index) => {
            const payrollTypeId = row.getAttribute('data-payroll-type-id');
            const voucherFormatId = row.getAttribute('data-voucher-format-id');

            const hiddenInput = document.createElement('input');
            hiddenInput.type = 'hidden';
            hiddenInput.name = 'VoucherFormats';
            hiddenInput.value = voucherFormatId;
            container.appendChild(hiddenInput);
        });
    }

    // Inicializar hidden inputs al cargar la página
    document.addEventListener('DOMContentLoaded', function() {
        updateHiddenInputs();
    });
</script>
