@model IEnumerable<_2FA.Data.Entities.PayrollTmpHeaderEntity>

@{
    ViewData["Title"] = "Index";
}

<div style="text-align: center;">
    <h2>Listado de Núminas en Proceso</h2>
</div>

<div class="m-0 row justify-content-center">
    <div class="col-md-10">
        <div class="card">
            <card-header>
                <div class="p-3">
                    <a class="btn-action" asp-action="Create"><i class="fa-solid fa-plus"></i></a>
                </div>
            </card-header>
            <div class="card-body">
                <table class="table" id="table2">
                    <thead>
                        <tr>
                            <th width="10%">
                                @Html.DisplayNameFor(model => model.StartDate)
                            </th>
                            <th width="10%">
                                @Html.DisplayNameFor(model => model.EndDate)
                            </th>
                            <th width="10%">
                                @Html.DisplayNameFor(model => model.Status)
                            </th>
                            <th width="15%">
                                @Html.DisplayNameFor(model => model.PaymentGroup)
                            </th>
                            <th width="40%">
                                @Html.DisplayNameFor(model => model.Notes)
                            </th>
                            <th width="15%">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model) {
                            <tr>
                                <td>
                                    @Html.DisplayFor(modelItem => item.StartDate)
                                </td>
                                <td>
                                    @Html.DisplayFor(modelItem => item.EndDate)
                                </td>
                                <td>
                                    @Html.DisplayFor(modelItem => item.Status)
                                </td>
                                <td>
                                    @(item?.PaymentGroup?.Name ?? "Sin nombre de Grupo")
                                </td>
                                <td>
                                    @(item?.ShortNotes ?? "")
                                </td>
                                <td>
                                    <a title="Editar registro" class="btn-index" asp-action="Edit" asp-route-id="@item?.Id"><i class="fa-solid fa-pen-to-square"></i></a>
                                    <a title="Detalle del registro" class="btn-index" asp-action="Details" asp-route-id="@item?.Id"><i class="fa-solid fa-list"></i></a>
                                    <a title="Borrar registro" class="btn-index" asp-action="Delete" asp-route-id="@item?.Id"><i class="fa-solid fa-trash-can"></i></a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
