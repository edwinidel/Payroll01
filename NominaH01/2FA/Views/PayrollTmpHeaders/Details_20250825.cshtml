        document.addEventListener("click", function(e) {
            if (e.target && e.target.id === "btnAddConcept") {
                const empId = e.target.getAttribute("data-employee-id");
                document.getElementById("PayrollTmpEmployeeId").value = empId;

                // mover modal al body si está incrustado en un partial
                const modalEl = document.getElementById("conceptModal");
                document.body.appendChild(modalEl);

                const modal = new bootstrap.Modal(modalEl);
                modal.show();
            }
        });

        // Calcular Total en tiempo real
        function calcularTotal() {
            const horas = parseFloat(document.getElementById("Hours").value) || 0;
            const monto = parseFloat(document.getElementById("UnitAmount").value) || 0;
            const factor = parseFloat(document.getElementById("PayFactor").value) || 1;
            document.getElementById("TotalAmount").value = (horas * monto * factor).toFixed(2);
        }

        document.getElementById("Hours").addEventListener("input", calcularTotal);
        document.getElementById("UnitAmount").addEventListener("input", calcularTotal);
        document.getElementById("PayFactor").addEventListener("input", calcularTotal);

        // Guardar Concepto vía AJAX
        document.getElementById("saveConceptBtn").addEventListener("click", function () {
            const form = document.getElementById("conceptForm");
            const data = new FormData(form);

            fetch('/PayrollTmpHeaders/AddConcept', {
                method: 'POST',
                body: data
            })
            .then(r => r.text())
            .then(html => {
                // recargar lista de conceptos
                document.getElementById("conceptsContainer").innerHTML = html;
                bootstrap.Modal.getInstance(document.getElementById("conceptModal")).hide();
                form.reset(); // limpiar formulario
            })
            .catch(err => alert("Error al guardar concepto: " + err));
        });
    </script>


