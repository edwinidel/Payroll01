@model IEnumerable<dynamic>

@{
    ViewData["Title"] = "Admin - Users";
}

<h2>Users</h2>

<table class="table">
    <thead>
        <tr>
            <th>Email</th>
            <th>Name</th>
            <th>Password Last Changed (UTC)</th>
            <th>Require Change On Expiry</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var u in Model)
    {
        <tr>
            <td>@u.Email</td>
            <td>@(u.FirstName + " " + u.LastName)</td>
            <td>@(u.PasswordLastChanged ?? "-")</td>
            <td>@(u.RequirePasswordChangeOnExpiry ? "Yes" : "No")</td>
            <td>
                <form asp-action="ToggleRequireChange" method="post">
                    <input type="hidden" name="id" value="@u.Id" />
                    <button class="btn btn-sm btn-primary">Toggle</button>
                    @Html.AntiForgeryToken()
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>
