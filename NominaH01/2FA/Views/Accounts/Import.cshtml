@model IEnumerable<_2FA.Models.AccountImportViewModel>

@{
    ViewData["Title"] = "Importar cuentas";
}

<div class="row justify-content-center">
    <div class="col-md-10">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h1>Importar cuentas desde Excel</h1>
            <a asp-action="Index" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Volver
            </a>
        </div>
    </div>
</div>

@if (Model == null || !Model.Any())
{
    <!-- Upload Form -->
    <div class="row mb-4 justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">Cargar archivo Excel</h5>
                </div>
                <div class="card-body">
                    <div class="alert alert-info d-flex justify-content-between align-items-center" role="alert">
                        <div>
                            <i class="fas fa-file-excel"></i>
                            Descargue la plantilla oficial para importar con la estructura correcta.
                        </div>
                        <a asp-action="DownloadTemplate" class="btn btn-success btn-sm">
                            <i class="fas fa-download"></i> Descargar plantilla
                        </a>
                    </div>

                    <form asp-action="Preview" method="post" enctype="multipart/form-data" id="uploadForm">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label for="excelFile" class="form-label">Seleccionar archivo Excel</label>
                            <input type="file" class="form-control" id="excelFile" name="excelFile" accept=".xlsx,.xls" />
                            <div class="form-text">
                                El archivo debe tener las columnas: AccountNumber (requerido), Description (opcional) y Clasification (requerido).
                            </div>
                        </div>
                        <button type="submit" class="btn btn-primary" id="previewBtn">
                            <i class="fas fa-eye"></i> Vista previa
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <!-- Preview Table -->
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="card-title mb-0">Vista previa de importación</h5>
                    <span class="badge bg-info">@Model.Count() filas encontradas</span>
                </div>
                <div class="card-body">
                    <div class="alert alert-info">
                        <i class="fas fa-info-circle"></i>
                        Revise la información antes de importar. Puede ajustar número, descripción y clasificación.
                        Las filas con errores no se importarán.
                    </div>

                    <form asp-action="SaveImported" method="post" id="importForm">
                        @Html.AntiForgeryToken()
                        <div class="table-responsive">
                            <table class="table table-striped table-hover" id="previewTable">
                                <thead class="table-dark">
                                    <tr>
                                        <th>#</th>
                                        <th>Número de cuenta *</th>
                                        <th>Descripción</th>
                                        <th>Clasificación *</th>
                                        <th>Estado</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (int i = 0; i < Model.Count(); i++)
                                    {
                                        var item = Model.ElementAt(i);
                                        <tr class="@(item.IsValid ? "" : "table-danger")">
                                            <td>@item.RowNumber</td>
                                            <td>
                                                <input type="hidden" asp-for="@Model.ElementAt(i).RowNumber" />
                                                <input type="hidden" asp-for="@Model.ElementAt(i).IsValid" />
                                                <input type="hidden" asp-for="@Model.ElementAt(i).ErrorMessage" />
                                                <input type="text" class="form-control form-control-sm @(item.IsValid ? "" : "is-invalid")"
                                                       asp-for="@Model.ElementAt(i).AccountNumber"
                                                       maxlength="50" required />
                                            </td>
                                            <td>
                                                <input type="text" class="form-control form-control-sm"
                                                       asp-for="@Model.ElementAt(i).Description"
                                                       maxlength="200" />
                                            </td>
                                            <td>
                                                <select class="form-control form-control-sm @(item.IsValid ? "" : "is-invalid")"
                                                        asp-for="@Model.ElementAt(i).Clasification"
                                                        asp-items="Html.GetEnumSelectList<_2FA.Data.Entities.AccountClasificationType>()">
                                                    <option value="">Seleccione una clasificación</option>
                                                </select>
                                            </td>
                                            <td>
                                                @if (item.IsValid)
                                                {
                                                    <span class="badge bg-success">
                                                        <i class="fas fa-check"></i> Válida
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-danger" title="@item.ErrorMessage">
                                                        <i class="fas fa-exclamation-triangle"></i> Error
                                                    </span>
                                                    <div class="small text-danger mt-1">@item.ErrorMessage</div>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <div class="mt-3 d-flex justify-content-between">
                            <a asp-action="Import" class="btn btn-secondary">
                                <i class="fas fa-arrow-left"></i> Cargar otro archivo
                            </a>

                            @if (Model.Any(m => m.IsValid))
                            {
                                <button type="submit" class="btn btn-success" id="importBtn">
                                    <i class="fas fa-upload"></i> Importar @Model.Count(m => m.IsValid) cuentas válidas
                                </button>
                            }
                            else
                            {
                                <button type="button" class="btn btn-danger" disabled>
                                    <i class="fas fa-exclamation-triangle"></i> No hay cuentas válidas para importar
                                </button>
                            }
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        $(document).ready(function() {
            // Initialize DataTable for preview
            if ($('#previewTable').length > 0) {
                $('#previewTable').DataTable({
                    "pageLength": 25,
                    "lengthMenu": [[10, 25, 50, -1], [10, 25, 50, "All"]],
                    "order": [[0, "asc"]],
                    "columnDefs": [
                        { "orderable": false, "targets": [1, 2, 3] },
                        { "searchable": false, "targets": [3] }
                    ],
                    "language": {
                        "lengthMenu": "Mostrar _MENU_ registros por página",
                        "zeroRecords": "No se encontraron registros",
                        "info": "Mostrando página _PAGE_ de _PAGES_",
                        "infoEmpty": "No hay registros disponibles",
                        "infoFiltered": "(filtrado de _MAX_ registros totales)",
                        "search": "Buscar:",
                        "paginate": {
                            "first": "Primero",
                            "last": "Último",
                            "next": "Siguiente",
                            "previous": "Anterior"
                        }
                    }
                });
            }

            // Handle form submission for preview
            $('#uploadForm').on('submit', function(e) {
                console.log('Form submit triggered');

                // Show loading state
                var previewBtn = $('#previewBtn');
                previewBtn.prop('disabled', true);
                previewBtn.html('<i class="fas fa-spinner fa-spin"></i> Processing...');
            });

            // Test button click
            $('#previewBtn').on('click', function(e) {
                console.log('Preview button clicked');
            });

            // Handle form submission for import
            $('#importForm').on('submit', function(e) {
                // Show loading state
                var importBtn = $('#importBtn');
                importBtn.prop('disabled', true);
                importBtn.html('<i class="fas fa-spinner fa-spin"></i> Importing...');
            });

            // Auto-resize text inputs
            $('input[type="text"]').on('input', function() {
                // Simple validation feedback
                var input = $(this);
                var isRequired = input.attr('required') !== undefined;
                var value = input.val().trim();

                if (isRequired && value === '') {
                    input.addClass('is-invalid');
                } else {
                    input.removeClass('is-invalid');
                }
            });
        });
    </script>
}