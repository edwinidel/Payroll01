@model _2FA.Data.Entities.DocumentTemplateEntity

@{
    ViewData["Title"] = "Ver plantilla";
}

<h2>@Model.Name</h2>

<div class="mb-3">
    @if (!string.IsNullOrEmpty(Model.LogoPath)) { <img src="/@Model.LogoPath" style="height:80px" /> }
    @if (!string.IsNullOrEmpty(Model.SignaturePath)) { <img src="/@Model.SignaturePath" style="height:80px" /> }
</div>

<div class="border p-3">
    @Html.Raw(Model.Content)
</div>

<p>
    <a class="btn btn-secondary" href="@Url.Action("Index")">Volver</a>
</p>
