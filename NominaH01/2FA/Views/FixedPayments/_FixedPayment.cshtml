@model _2FA.Data.Entities.FixedPaymentEntity


<div class="form-group">
    <a title="Regresar" class="btn-action" asp-action="Index"><i class="fa-solid fa-left-long"></i></a>
    <button title="Guardar" class="btn-action" type="submit"><i class="fa-solid fa-floppy-disk"></i></button>
</div>
<br>

<div class="row">
    <div class="col-md-8">
        <div class="form-group">
            <label asp-for="EmployeeId" class="control-label"></label>
            <select asp-for="EmployeeId" class="form-control" asp-items="ViewBag.EmployeeId"></select>
            <span asp-validation-for="EmployeeId" class="text-danger"></span>
        </div>
    </div>
    <div class="col-md-4">
        <div class="form-group">
            <label asp-for="PaymentConceptId" class="control-label"></label>
            <select asp-for="PaymentConceptId" class="form-control" asp-items="ViewBag.PaymentConceptId"></select>
            <span asp-validation-for="PaymentConceptId" class="text-danger"></span>
        </div>
    </div>
</div>
<div class="row">
    <div class="col-md-6">
        <div class="form-group">
            <label asp-for="PaymentFrequency" class="control-label"></label>
            <input asp-for="PaymentFrequency" class="form-control" />
            <span asp-validation-for="PaymentFrequency" class="text-danger"></span>
        </div>
    </div>
    <div class="col-md-4">
        <div class="form-group">
            <label asp-for="PayAmount" class="control-label"></label>
            <input asp-for="PayAmount" class="form-control" />
            <span asp-validation-for="PayAmount" class="text-danger"></span>
        </div>
    </div>
    <div class="col-md-2">
        <div style="text-align: center;">
            <label asp-for="IsActive" class="control-label"></label>
        </div>
        <div class="form-check form-switch d-flex justify-content-center align-items-center" style="min-height: 50px;">
            <input class="form-check-input" asp-for="IsActive" type="checkbox" id="flexSwitchCheckDefault" style="font-size: 20px;">
            <label class="form-check-label" for="flexSwitchCheckDefault"></label>
        </div>
    </div>
</div>
<div class="form-group form-check">
    <label class="form-check-label">
        <input class="form-check-input" asp-for="IsActive" /> @Html.DisplayNameFor(model => model.IsActive)
    </label>
</div>
<div class="row">
    <div class="col-md-4">
        <div class="form-group">
            <label asp-for="InitDate" class="control-label"></label>
            <input asp-for="InitDate" class="form-control" />
            <span asp-validation-for="InitDate" class="text-danger"></span>
        </div>
    </div>
    <div class="col-md-4">
        <div class="form-group">
            <label asp-for="EndDate" class="control-label"></label>
            <input asp-for="EndDate" class="form-control" />
            <span asp-validation-for="EndDate" class="text-danger"></span>
        </div>
    </div>
    <div class="col-md-4">
        <div class="form-group">
            <label asp-for="AuthorizeBy" class="control-label"></label>
            <input asp-for="AuthorizeBy" class="form-control" />
            <span asp-validation-for="AuthorizeBy" class="text-danger"></span>
        </div>
    </div>
</div>
<div class="col-md-12">
    <div class="form-group">
        <label asp-for="Comentary" class="control-label"></label>
        <textarea asp-for="Comentary" class="form-control" rows="5"></textarea>
        <span asp-validation-for="Comentary" class="text-danger"></span>
    </div>
</div>
