@model _2FA.Data.Entities.CountryEntity

@{
    ViewData["Title"] = "Country Details";
}

<style>
    .col-md-3 {
        border-right: 1px solid #2b2a2a; /* Separador delicado */
    }
    .col-md-3:last-child {
        border-right: none; /* Sin borde en la última columna */
    }

    .izquierdo, .derecho {
        height: 100px; /* Ejemplo de altura para los divs de contenido */
    }
</style>

<div>
    <a title="Editar" class="btn btn-primary" asp-action="Edit" asp-route-id="@Model?.Id"><i class="fa-solid fa-pen-to-square"></i></a> 
    <a title="Regresar" class="btn btn-primary" asp-action="Index"><i class="fa-solid fa-left-long"></i></a>
</div>
<div class="Title">
    <h3>Detalle de País - @(Model?.Name_es ?? "N/A")</h3>
</div>
<div class="m-0 row justify-content-center">
    <table>
        <tbody>
            <tr width="100%">
                <td>
                    <partial name="_CountryDetails" model="@Model" />
                </td>
            </tr>
            <br />
            <tr width="100%">
                <td>
                    <div class="m-0 row justify-content-center">
                        <div class="card">
                            <div class="card-header">
                                <h4 class="card-title"></h4>
                            </div>
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-sm-6">
                                        <h4>Listado de Provincias</h4>
                                        <partial name="_StatesList" model="@Model" />
                                    </div>
                                    <div class="col-sm-6">
                                        <h4>Listado de Ciudades</h4>
                                        <partial name="_CitiesList" model="@Model" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </td>
            </tr>
        </tbody>
    </table>
</div>
