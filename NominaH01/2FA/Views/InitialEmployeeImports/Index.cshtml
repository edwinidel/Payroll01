@model _2FA.Models.InitialEmployeeImportViewModel

@{
    ViewData["Title"] = "Importación inicial de empleados";
}

<div style="text-align: center;">
    <h2>Importación inicial de empleados</h2>
    <p class="text-muted">Disponible solo para SuperAdmin sobre la compañía seleccionada.</p>
</div>

<div class="row justify-content-center">
    <div class="col-md-11">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">@TempData["Success"]</div>
        }

        @if (TempData["Warning"] != null)
        {
            <div class="alert alert-warning">@TempData["Warning"]</div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }

        <div class="card mb-4">
            <div class="card-header">
                <div class="p-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
                    <div>
                        <h5 class="mb-1">Compañía activa: @Model.CompanyName</h5>
                        <small class="text-muted">Empleados actuales: @Model.ExistingEmployeeCount</small>
                    </div>
                    <div class="d-flex gap-2">
                        <a class="btn btn-outline-secondary" asp-controller="SuperAdminManagement" asp-action="Index">
                            <i class="fa-solid fa-left-long"></i>
                            Regresar
                        </a>
                        <a class="btn btn-primary" asp-action="DownloadTemplate">
                            <i class="fa-solid fa-file-excel"></i>
                            Descargar plantilla XLSX
                        </a>
                    </div>
                </div>
            </div>
            <div class="card-body">
                <p>
                    Cargue un archivo XLSX con los empleados iniciales de la compañía. La plantilla incluye la hoja
                    <strong>Empleados</strong> y una hoja de <strong>Catálogos</strong> con valores válidos.
                </p>

                <ul>
                    <li>Campos mínimos recomendados: <strong>Codigo</strong>, <strong>Nombres</strong>, <strong>Apellidos</strong>, <strong>Cedula</strong>, <strong>FechaIngreso</strong>, <strong>TipoSalario</strong>, <strong>HorasRegulares</strong>.</li>
                    <li>Las columnas de catálogos aceptan nombre o ID.</li>
                    <li>Si una columna de catálogo queda vacía, se toma el primer valor configurado para la compañía.</li>
                </ul>

                @if (Model.PrerequisiteIssues.Any())
                {
                    <div class="alert alert-danger">
                        <strong>No se puede importar todavía.</strong>
                        <ul class="mb-0 mt-2">
                            @foreach (var issue in Model.PrerequisiteIssues)
                            {
                                <li>@issue</li>
                            }
                        </ul>
                    </div>
                }

                <form asp-action="Preview" method="post" enctype="multipart/form-data" class="mt-3">
                    @Html.AntiForgeryToken()
                    <div class="row align-items-end g-3">
                        <div class="col-md-9">
                            <label for="excelFile" class="form-label">Archivo XLSX</label>
                            <input id="excelFile" name="excelFile" type="file" class="form-control" accept=".xlsx" @(Model.CanImport ? null : "disabled") />
                        </div>
                        <div class="col-md-3">
                            <button type="submit" class="btn btn-success w-100" @(Model.CanImport ? null : "disabled")>
                                <i class="fa-solid fa-magnifying-glass"></i>
                                Generar vista previa
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        @if (Model.HasPreview)
        {
            <div class="row mb-3">
                <div class="col-md-4">
                    <div class="card border-success">
                        <div class="card-body text-center">
                            <h6 class="text-muted">Filas válidas</h6>
                            <h3 class="text-success">@Model.ValidRowsCount</h3>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card border-danger">
                        <div class="card-body text-center">
                            <h6 class="text-muted">Filas con errores</h6>
                            <h3 class="text-danger">@Model.InvalidRowsCount</h3>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card border-primary">
                        <div class="card-body text-center">
                            <h6 class="text-muted">Total evaluado</h6>
                            <h3 class="text-primary">@Model.PreviewRows.Count</h3>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-header">
                    <div class="p-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
                        <h5 class="mb-0">Vista previa</h5>
                        <form asp-action="SaveImported" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-primary" @(Model.ValidRowsCount > 0 ? null : "disabled")>
                                <i class="fa-solid fa-floppy-disk"></i>
                                Importar filas válidas
                            </button>
                        </form>
                    </div>
                </div>
                <div class="card-body table-responsive">
                    <table class="table table-striped table-bordered align-middle" id="table2">
                        <thead>
                            <tr>
                                <th>Fila</th>
                                <th>Código</th>
                                <th>Empleado</th>
                                <th>Cédula</th>
                                <th>Tipo salario</th>
                                <th>Estatus</th>
                                <th>Resultado</th>
                                <th>Detalle</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in Model.PreviewRows)
                            {
                                <tr>
                                    <td>@row.RowNumber</td>
                                    <td>@row.Code</td>
                                    <td>@row.FirstName @row.LastName</td>
                                    <td>@row.IdDocument</td>
                                    <td>@row.SalaryType</td>
                                    <td>@row.Status</td>
                                    <td>
                                        @if (row.IsValid)
                                        {
                                            <span class="badge bg-success">Válida</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Con errores</span>
                                        }
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrWhiteSpace(row.ErrorMessage))
                                        {
                                            <div class="text-danger mb-1">@row.ErrorMessage</div>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(row.Notes))
                                        {
                                            <div class="text-muted small">@row.Notes</div>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}