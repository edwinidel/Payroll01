@model _2FA.Data.Entities.OtcConfigurationEntity
@{
    ViewData["Title"] = "Eliminar configuración OTC";
}

<h1>Eliminar configuración</h1>

<h4>¿Confirma que desea eliminar esta configuración?</h4>
<hr />
<div>
    <dl class="row">
        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Name)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.Name)</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.LoginEndpoint)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.LoginEndpoint)</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.CalculateEndpoint)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.CalculateEndpoint)</dd>
    </dl>

    <form asp-action="Delete">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <div class="d-flex gap-2">
            <input type="submit" value="Eliminar" class="btn btn-danger" />
            <a asp-action="Index" class="btn btn-outline-secondary">Regresar</a>
        </div>
    </form>
</div>
