@model _2FA.Data.Entities.UniformDeliveryEntity
@{
    ViewData["Title"] = "Nuevo Uniforme";
}

<div style="text-align: center;">
    <h2>Registrar Entrega de Uniforme</h2>
</div>

<div class="m-0 row justify-content-center">
    <div class="col-md-8">
        <div class="card">
            <card-header>
                <div class="p-3"></div>
            </card-header>
            <div class="card-body">
                <div class="row">
                    <div>
                        <form asp-action="Create">
                            @if (!ViewData.ModelState.IsValid)
                            {
                                <div class="alert alert-warning alert-dismissible fade show" role="alert">
                                    <i class="bi bi-exclamation-triangle-fill"></i>
                                    <strong>¡Atención!</strong> Revise los errores antes de guardar.
                                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                                </div>
                            }

                            <div class="form-group mb-3">
                                <a title="Regresar" class="btn-action" asp-action="Index"><i class="fa-solid fa-left-long"></i></a>
                                <button title="Guardar" class="btn-action" type="submit"><i class="fa-solid fa-floppy-disk"></i></button>
                            </div>

                            <div class="row g-3">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label asp-for="EmployeeId" class="control-label"></label>
                                        <select asp-for="EmployeeId" class="form-select" asp-items="ViewBag.EmployeeId"></select>
                                        <span asp-validation-for="EmployeeId" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label asp-for="ItemName" class="control-label"></label>
                                        <input asp-for="ItemName" class="form-control" />
                                        <span asp-validation-for="ItemName" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label asp-for="Brand" class="control-label"></label>
                                        <input asp-for="Brand" class="form-control" />
                                        <span asp-validation-for="Brand" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label asp-for="Size" class="control-label"></label>
                                        <input asp-for="Size" class="form-control" />
                                        <span asp-validation-for="Size" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label asp-for="Color" class="control-label"></label>
                                        <input asp-for="Color" class="form-control" />
                                        <span asp-validation-for="Color" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label asp-for="Quantity" class="control-label"></label>
                                        <input asp-for="Quantity" class="form-control" />
                                        <span asp-validation-for="Quantity" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label asp-for="DeliveryDate" class="control-label"></label>
                                        <input asp-for="DeliveryDate" class="form-control" type="date" />
                                        <span asp-validation-for="DeliveryDate" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label asp-for="ValidityDays" class="control-label"></label>
                                        <input asp-for="ValidityDays" class="form-control" />
                                        <span asp-validation-for="ValidityDays" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label asp-for="ExpirationDate" class="control-label"></label>
                                        <input asp-for="ExpirationDate" class="form-control" type="date" readonly />
                                        <span asp-validation-for="ExpirationDate" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label asp-for="AlertDaysBefore" class="control-label"></label>
                                        <input asp-for="AlertDaysBefore" class="form-control" />
                                        <span asp-validation-for="AlertDaysBefore" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-md-12">
                                    <div class="form-group">
                                        <label asp-for="Notes" class="control-label"></label>
                                        <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                                        <span asp-validation-for="Notes" class="text-danger"></span>
                                    </div>
                                </div>
                            </div>

                            @if (!ViewData.ModelState.IsValid)
                            {
                                <div class="mt-3">
                                    <div class="card border-danger">
                                        <div class="card-header bg-danger text-white">
                                            <h5 class="mb-0">
                                                <i class="bi bi-exclamation-circle"></i>
                                                Errores de Validación Detectados
                                            </h5>
                                        </div>
                                        <div class="card-body">
                                            <p class="card-text">Corrija los siguientes errores:</p>
                                            <div asp-validation-summary="All" class="text-danger"></div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        (function () {
            const deliveryInput = document.getElementById('DeliveryDate');
            const validityInput = document.getElementById('ValidityDays');
            const expirationInput = document.getElementById('ExpirationDate');

            function updateExpiration() {
                if (!deliveryInput || !validityInput || !expirationInput) return;
                const deliveryValue = deliveryInput.value;
                const validityValue = parseInt(validityInput.value || '0', 10);
                if (!deliveryValue || isNaN(validityValue)) return;

                const deliveryDate = new Date(deliveryValue + 'T00:00:00');
                deliveryDate.setDate(deliveryDate.getDate() + validityValue);

                const year = deliveryDate.getFullYear();
                const month = String(deliveryDate.getMonth() + 1).padStart(2, '0');
                const day = String(deliveryDate.getDate()).padStart(2, '0');
                expirationInput.value = `${year}-${month}-${day}`;
            }

            deliveryInput?.addEventListener('change', updateExpiration);
            validityInput?.addEventListener('input', updateExpiration);
            updateExpiration();
        })();
    </script>
}
