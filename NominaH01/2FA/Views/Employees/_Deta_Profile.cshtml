@model _2FA.Data.Entities.EmployeeEntity

<div class="row g-4 align-items-center">
    <div class="container mt-4">
        <div class="row">
            <!-- Columna izquierda -->
            <div class="col-md-8">
                <div class="row mb-2">
                    <div class="col">
                        <div class="row">
                            <div class="col-6">
                                <dl class="row">
                                    <dt class="col-sm-12">
                                        @Html.DisplayNameFor(model => model.DateOfBird)
                                    </dt>
                                    <dd class="col-sm-12">
                                        @(Model.DateOfBird.HasValue ? Model.DateOfBird.Value.ToString("dd/MM/yyyy") : "")
                                    </dd>
                                </dl>
                            </div>
                            <div class="col-6">
                                <dl class="row">
                                    <dt class="col-sm-12">
                                        @Html.DisplayNameFor(model => model.CivilStatus)
                                    </dt>
                                    <dd class="col-sm-12">
                                        @Html.DisplayFor(model => model.CivilStatus)
                                    </dd>
                                </dl>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="row mb-2">
                    <div class="col">
                        <div class="row">
                            <div class="col-3">
                                <dl class="row">
                                    <dt class="col-sm-12">
                                        @Html.DisplayNameFor(model => model.BloodType)
                                    </dt>
                                    <dd class="col-sm-12">
                                        @Html.DisplayFor(model => model.BloodType)
                                    </dd>
                                </dl>
                            </div>
                            <div class="col-3">
                                <dl class="row">
                                    <dt class="col-sm-12">
                                        @Html.DisplayNameFor(model => model.FixedPhone)
                                    </dt>
                                    <dd class="col-sm-12">
                                        @Html.DisplayFor(model => model.FixedPhone)
                                    </dd>
                                </dl>
                            </div>
                            <div class="col-3">
                                <dl class="row">
                                    <dt class="col-sm-12">
                                        @Html.DisplayNameFor(model => model.CellPhone)
                                    </dt>
                                    <dd class="col-sm-12">
                                        @Html.DisplayFor(model => model.CellPhone)
                                    </dd>
                                </dl>
                            </div>
                            <div class="col-3">
                                <dl class="row">
                                    <dt class="col-sm-12">
                                        @Html.DisplayNameFor(model => model.CEMAIL)
                                    </dt>
                                    <dd class="col-sm-12">
                                        @Html.DisplayFor(model => model.CEMAIL)
                                    </dd>
                                </dl>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-12">
                    <dl class="row">
                        <dt class="col-sm-12">
                            @Html.DisplayNameFor(model => model.CDIR1)
                        </dt>
                        <dd class="col-sm-12">
                            @Html.DisplayFor(model => model.CDIR1)
                        </dd>
                    </dl>
                </div>
                <div class="col-md-12">
                    <dl class="row">
                        <dt class="col-sm-12">
                            @Html.DisplayNameFor(model => model.CDIR2)
                        </dt>
                            @Html.DisplayFor(model => model.CDIR2)
                        <dd class="col-sm-12">
                        </dd>
                    </dl>
                </div>
            </div>

            <!-- Columna derecha -->
            <div class="col-md-4 d-flex align-items-center">
                <div class="w-100 p-3 border bg-white d-flex align-items-center justify-content-center">
                    <img id="previewImage" src="@(string.IsNullOrEmpty(Model?.PhotoPath) ? "https://via.placeholder.com/250x250?text=Foto" : $"/{Model.PhotoPath}")" class="img-fluid" style="max-height: 200px; max-width: 200px;" alt="Foto">
                </div>
            </div>
        </div>
    </div>
</div>
