@model _2FA.Data.Entities.EmployeeEntity

<!-- Modal para Observaciones de Empleado -->
<div class="modal fade" id="observationHistoryModal" tabindex="-1" aria-labelledby="observationHistoryModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="observationHistoryModalLabel">Observaciones de empleado</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <span class="fw-semibold">Empleado:</span>
                    <span>@Model?.FullName</span>
                </div>
                <div class="alert alert-info" role="alert">
                    Este modal está listo para conectar con el listado y registro de observaciones. Reemplace este contenido cuando se añadan los endpoints y el formulario definitivo.
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>
