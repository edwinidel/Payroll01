@model _2FA.Data.Entities.EmployeeEntity

@{
    ViewData["Title"] = "Create";
}

<h1>Nuevo Empleado</h1>

<hr />
<div class="m-0 row justify-content-center">
    <div class="col-md-10">
        <form asp-action="Create" enctype="multipart/form-data">
            <!-- Alerta de errores de validación -->
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-warning alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <strong>¡Atención!</strong> Se encontraron errores de validación. Por favor, revise el listado de errores que aparece al final del formulario.
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <div class="card">
                <div class="card-header">
                    <div class="p-3">
                        <a class="btn-action" asp-action="Index" title="Regresar"><i class="fa-solid fa-left-long"></i></a>
                        <button title="Guardar" class="btn-action" type="submit"><i class="fa-solid fa-floppy-disk"></i></button>
                    </div>
                </div>
                <br />
                <div class="card-body">
                    <partial name="_Employees" model="Model" />
                </div>
            </div>

            <!-- Listado de errores de validación -->
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="mt-3">
                    <div class="card border-danger">
                        <div class="card-header bg-danger text-white">
                            <h5 class="mb-0">
                                <i class="bi bi-exclamation-circle"></i>
                                Errores de Validación Detectados
                            </h5>
                        </div>
                        <div class="card-body">
                            <p class="card-text">Por favor, corrija los siguientes errores antes de guardar:</p>
                            <div asp-validation-summary="All" class="text-danger"></div>
                        </div>
                    </div>
                </div>
            }
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function loadPhoto(event) {
            const image = document.getElementById('previewImage');
            const file = event.target.files[0];
            if (file) {
            const reader = new FileReader();
            reader.onload = function(e) {
                image.src = e.target.result;
            }
            reader.readAsDataURL(file);
            }
        }
    </script>

    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
